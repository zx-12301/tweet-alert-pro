/* 全局变量 - 现代设计系统 */
page {
  /* 主色调 */
  --primary-color: #2563eb;
  --primary-dark: #1d4ed8;
  --primary-light: #3b82f6;
  --primary-50: #eff6ff;
  --primary-100: #dbeafe;

  /* 辅助色 */
  --secondary-color: #7c3aed;
  --accent-purple: #8b5cf6;
  --accent-pink: #ec4899;

  /* 状态色 */
  --success-color: #10b981;
  --success-light: #d1fae5;
  --warning-color: #f59e0b;
  --warning-light: #fef3c7;
  --danger-color: #ef4444;
  --danger-light: #fee2e2;
  --info-color: #06b6d4;
  --info-light: #cffafe;

  /* 中性色 */
  --bg-color: #f8fafc;
  --bg-gradient-start: #f0f9ff;
  --bg-gradient-end: #f8fafc;
  --card-bg: #ffffff;
  --surface-bg: #f1f5f9;

  /* 文字颜色 */
  --text-primary: #0f172a;
  --text-secondary: #475569;
  --text-muted: #94a3b8;
  --text-disabled: #cbd5e1;

  /* 边框颜色 */
  --border-color: #e2e8f0;
  --border-light: rgba(226, 232, 240, 0.5);

  /* 阴影系统 */
  --shadow-xs: 0 1rpx 2rpx rgba(0, 0, 0, 0.04);
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 30rpx rgba(0, 0, 0, 0.12);
  --shadow-xl: 0 16rpx 48rpx rgba(0, 0, 0, 0.16);
  --shadow-2xl: 0 24rpx 64rpx rgba(0, 0, 0, 0.2);

  /* 彩色阴影 */
  --shadow-primary: 0 8rpx 24rpx rgba(37, 99, 235, 0.25);
  --shadow-success: 0 8rpx 24rpx rgba(16, 185, 129, 0.25);
  --shadow-warning: 0 8rpx 24rpx rgba(245, 158, 11, 0.25);
  --shadow-danger: 0 8rpx 24rpx rgba(239, 68, 68, 0.25);

  /* 圆角系统 */
  --radius-xs: 8rpx;
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 20rpx;
  --radius-xl: 24rpx;
  --radius-2xl: 32rpx;
  --radius-full: 9999rpx;

  /* 渐变色 */
  --gradient-blue: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  --gradient-purple: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
  --gradient-pink: linear-gradient(135deg, #ec4899 0%, #db2777 100%);
  --gradient-green: linear-gradient(135deg, #10b981 0%, #059669 100%);
  --gradient-orange: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
  --gradient-red: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);

  /* 缓动函数 */
  --ease-out: cubic-bezier(0.4, 0, 0.2, 1);
  --ease-in-out: cubic-bezier(0.4, 0, 0.6, 1);
  --ease-spring: cubic-bezier(0.175, 0.885, 0.32, 1.275);

  /* 布局 */
  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 20rpx;
  --spacing-xl: 24rpx;
  --spacing-2xl: 32rpx;
  --spacing-3xl: 48rpx;

  /* 字体 */
  --font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'HarmonyOS Sans', 'Microsoft YaHei', sans-serif;

  /* 应用全局样式 */
  background: linear-gradient(180deg, var(--bg-gradient-start) 0%, var(--bg-gradient-end) 100%);
  font-family: var(--font-family);
  min-height: 100vh;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
}

/* ==================== 基础样式 ==================== */
/* 通用容器 */
.container {
  padding: var(--spacing-lg);
}

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--bg-gradient-start) 0%, var(--bg-gradient-end) 100%);
}

/* ==================== 卡片系统 ==================== */
/* 基础卡片 */
.card {
  background: var(--card-bg);
  border-radius: var(--radius-xl);
  padding: var(--spacing-2xl);
  margin-bottom: var(--spacing-xl);
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--border-light);
  transition: all 0.3s var(--ease-out);
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.8), transparent);
  pointer-events: none;
}

.card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

/* 悬浮卡片 */
.card-hover {
  transition: all 0.3s var(--ease-out);
}

.card-hover:active {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-lg);
}

/* 卡片样式 - 高级感 */
.card {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
  border: 1rpx solid rgba(226, 232, 240, 0.6);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

/* 渐变卡片 */
.card-gradient {
  background: var(--gradient-purple);
  color: #ffffff;
  border: none;
  position: relative;
  overflow: hidden;
}

.card-gradient::after {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 100%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  pointer-events: none;
}

.card-gradient-blue {
  background: var(--gradient-blue);
  color: #ffffff;
  border: none;
}

.card-gradient-green {
  background: var(--gradient-green);
  color: #ffffff;
  border: none;
}

.card-gradient-purple {
  background: var(--gradient-purple);
  color: #ffffff;
  border: none;
}

.card-gradient-orange {
  background: var(--gradient-orange);
  color: #ffffff;
  border: none;
}

.card-gradient-red {
  background: var(--gradient-red);
  color: #ffffff;
  border: none;
}

/* ==================== 标题系统 ==================== */
.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.5rpx;
  line-height: 1.3;
}

.page-subtitle {
  font-size: 26rpx;
  color: var(--text-muted);
  line-height: 1.5;
  margin-top: var(--spacing-xs);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-xl);
  letter-spacing: -0.3rpx;
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: var(--spacing-xs);
}

/* ==================== 按钮系统 ==================== */
/* 基础按钮 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-lg) var(--spacing-2xl);
  border-radius: var(--radius-md);
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s var(--ease-out);
  cursor: pointer;
  white-space: nowrap;
}

.btn:active {
  transform: scale(0.95);
}

.btn-primary {
  background: var(--gradient-blue);
  color: #ffffff;
  box-shadow: var(--shadow-primary);
}

.btn-primary:active {
  box-shadow: var(--shadow-md);
  transform: translateY(2rpx);
}

.btn-secondary {
  background: var(--surface-bg);
  color: var(--text-primary);
  border: 1rpx solid var(--border-color);
}

.btn-secondary:active {
  background: var(--border-color);
}

.btn-danger {
  background: var(--gradient-red);
  color: #ffffff;
  box-shadow: var(--shadow-danger);
}

.btn-danger:active {
  box-shadow: var(--shadow-md);
  transform: translateY(2rpx);
}

.btn-success {
  background: var(--gradient-green);
  color: #ffffff;
  box-shadow: var(--shadow-success);
}

.btn-ghost {
  background: transparent;
  color: var(--text-secondary);
  padding: var(--spacing-md) var(--spacing-xl);
}

.btn-ghost:active {
  background: var(--surface-bg);
}

/* 按钮尺寸 */
.btn-sm {
  padding: var(--spacing-md) var(--spacing-xl);
  font-size: 26rpx;
  border-radius: var(--radius-sm);
}

.btn-lg {
  padding: var(--spacing-2xl) var(--spacing-3xl);
  font-size: 36rpx;
  border-radius: var(--radius-lg);
}

/* 按钮状态 */
.btn:disabled {
  opacity: 0.5;
  pointer-events: none;
}

.btn.loading {
  position: relative;
  color: transparent;
}

.btn.loading::after {
  content: '';
  position: absolute;
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(255,255,255,0.3);
  border-top-color: #ffffff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* 按钮样式 - 高级感 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #ffffff;
  border-radius: var(--radius-md);
  padding: 28rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3);
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.2);
}

.btn-secondary {
  background: var(--bg-color);
  color: var(--text-primary);
  border-radius: var(--radius-md);
  padding: 28rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: 1rpx solid var(--border-color);
  transition: all 0.2s ease;
}

.btn-secondary:active {
  background: var(--border-color);
}

.btn-danger {
  background: linear-gradient(135deg, var(--danger-color) 0%, #dc2626 100%);
  color: #ffffff;
  border-radius: var(--radius-md);
  padding: 28rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(239, 68, 68, 0.3);
}

/* ==================== 标签系统 ==================== */
.tag {
  display: inline-flex;
  align-items: center;
  gap: var(--spacing-xs);
  padding: var(--spacing-sm) var(--spacing-lg);
  border-radius: var(--radius-lg);
  font-size: 22rpx;
  font-weight: 600;
  transition: all 0.2s var(--ease-out);
}

.tag-primary {
  background: linear-gradient(135deg, var(--primary-50) 0%, var(--primary-100) 100%);
  color: var(--primary-color);
  border: 1rpx solid rgba(37, 99, 235, 0.2);
}

.tag-success {
  background: var(--success-light);
  color: var(--success-color);
  border: 1rpx solid rgba(16, 185, 129, 0.2);
}

.tag-warning {
  background: var(--warning-light);
  color: var(--warning-color);
  border: 1rpx solid rgba(245, 158, 11, 0.2);
}

.tag-danger {
  background: var(--danger-light);
  color: var(--danger-color);
  border: 1rpx solid rgba(239, 68, 68, 0.2);
}

.tag-info {
  background: var(--info-light);
  color: var(--info-color);
  border: 1rpx solid rgba(6, 182, 212, 0.2);
}

.tag-outline {
  background: transparent;
  color: var(--text-secondary);
  border: 1rpx solid var(--border-color);
}

/* 标签尺寸 */
.tag-sm {
  padding: var(--spacing-xs) var(--spacing-md);
  font-size: 20rpx;
  border-radius: var(--radius-md);
}

.tag-lg {
  padding: var(--spacing-md) var(--spacing-xl);
  font-size: 26rpx;
  border-radius: var(--radius-xl);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  margin: 24rpx;
  box-shadow: var(--shadow-md);
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: var(--text-muted);
  text-align: center;
  line-height: 1.6;
  max-width: 500rpx;
}

/* 加载动画 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--border-color), transparent);
  margin: 24rpx 0;
}

/* 网格布局 */
.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.grid-3 {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 20rpx;
}

/* 弹性布局 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

/* 文字截断 */
.text-truncate {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 安全区域 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* TabBar 页面容器 - 防止内容被遮挡 */
page.tabbar-page {
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

/* 通用底部安全区域类 */
.pb-safe {
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

.pb-safe-large {
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ==================== 动画系统 ==================== */
/* 淡入 */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInLeft {
  from {
    opacity: 0;
    transform: translateX(-40rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes fadeInRight {
  from {
    opacity: 0;
    transform: translateX(40rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

/* 滑动 */
@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

@keyframes slideDown {
  from {
    transform: translateY(-100%);
  }
  to {
    transform: translateY(0);
  }
}

/* 缩放 */
@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.8);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes scaleOut {
  from {
    opacity: 1;
    transform: scale(1);
  }
  to {
    opacity: 0;
    transform: scale(0.8);
  }
}

/* 弹跳 */
@keyframes bounceIn {
  0% {
    opacity: 0;
    transform: scale(0.3);
  }
  50% {
    opacity: 1;
    transform: scale(1.05);
  }
  70% {
    transform: scale(0.9);
  }
  100% {
    transform: scale(1);
  }
}

/* 旋转 */
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes spinReverse {
  from { transform: rotate(360deg); }
  to { transform: rotate(0deg); }
}

/* 脉冲 */
@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.5;
    transform: scale(1.05);
  }
}

/* 波纹 */
@keyframes ripple {
  0% {
    transform: scale(0);
    opacity: 0.8;
  }
  100% {
    transform: scale(4);
    opacity: 0;
  }
}

/* 摇晃 */
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-10rpx); }
  20%, 40%, 60%, 80% { transform: translateX(10rpx); }
}

/* 呼吸 */
@keyframes breathe {
  0%, 100% {
    transform: scale(1);
    opacity: 0.1;
  }
  50% {
    transform: scale(1.1);
    opacity: 0.15;
  }
}

/* 加载动画 */
@keyframes shimmer {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

/* 动画工具类 */
.animate-fade-in {
  animation: fadeIn 0.4s var(--ease-out);
}

.animate-fade-in-up {
  animation: fadeInUp 0.5s var(--ease-out);
}

.animate-fade-in-down {
  animation: fadeInDown 0.5s var(--ease-out);
}

.animate-fade-in-left {
  animation: fadeInLeft 0.5s var(--ease-out);
}

.animate-fade-in-right {
  animation: fadeInRight 0.5s var(--ease-out);
}

.animate-slide-up {
  animation: slideUp 0.5s var(--ease-out);
}

.animate-scale-in {
  animation: scaleIn 0.4s var(--ease-spring);
}

.animate-bounce-in {
  animation: bounceIn 0.6s var(--ease-spring);
}

.animate-pulse {
  animation: pulse 2s ease-in-out infinite;
}

.animate-shimmer {
  animation: shimmer 2s infinite;
}

/* 动画延迟 */
.animate-delay-100 { animation-delay: 0.1s; }
.animate-delay-200 { animation-delay: 0.2s; }
.animate-delay-300 { animation-delay: 0.3s; }
.animate-delay-400 { animation-delay: 0.4s; }
.animate-delay-500 { animation-delay: 0.5s; }

/* ==================== 特效系统 ==================== */
/* 微光效果 - 骨架屏 */
.skeleton {
  background: linear-gradient(
    90deg,
    #f1f5f9 0%,
    #e2e8f0 20%,
    #f1f5f9 40%,
    #f1f5f9 100%
  );
  background-size: 200% 100%;
  animation: shimmer 1.8s infinite;
  border-radius: var(--radius-md);
}

.skeleton-text {
  height: 28rpx;
  margin-bottom: var(--spacing-md);
}

.skeleton-text-sm {
  height: 22rpx;
  width: 60%;
  margin-bottom: var(--spacing-sm);
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-xl);
}

/* 毛玻璃效果 */
.glass {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.glass-dark {
  background: rgba(15, 23, 42, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.glass-colored {
  background: rgba(59, 130, 246, 0.1);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(59, 130, 246, 0.2);
}

/* 光晕效果 */
.glow {
  box-shadow: 0 0 20rpx rgba(37, 99, 235, 0.4);
}

.glow-primary {
  box-shadow: 0 0 20rpx rgba(37, 99, 235, 0.4);
}

.glow-success {
  box-shadow: 0 0 20rpx rgba(16, 185, 129, 0.4);
}

.glow-warning {
  box-shadow: 0 0 20rpx rgba(245, 158, 11, 0.4);
}

.glow-danger {
  box-shadow: 0 0 20rpx rgba(239, 68, 68, 0.4);
}

/* 浮动效果 */
.float {
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

/* 渐变文字 */
.gradient-text {
  background: var(--gradient-blue);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ==================== 工具类 ==================== */
/* 布局 */
.flex { display: flex; }
.flex-inline { display: inline-flex; }
.flex-col { flex-direction: column; }
.flex-row { flex-direction: row; }
.flex-wrap { flex-wrap: wrap; }
.flex-nowrap { flex-wrap: nowrap; }

/* 对齐 */
.items-start { align-items: flex-start; }
.items-center { align-items: center; }
.items-end { align-items: flex-end; }
.items-stretch { align-items: stretch; }

.justify-start { justify-content: flex-start; }
.justify-center { justify-content: center; }
.justify-end { justify-content: flex-end; }
.justify-between { justify-content: space-between; }
.justify-around { justify-content: space-around; }

/* 间距 */
.gap-xs { gap: var(--spacing-xs); }
.gap-sm { gap: var(--spacing-sm); }
.gap-md { gap: var(--spacing-md); }
.gap-lg { gap: var(--spacing-lg); }
.gap-xl { gap: var(--spacing-xl); }

.p-xs { padding: var(--spacing-xs); }
.p-sm { padding: var(--spacing-sm); }
.p-md { padding: var(--spacing-md); }
.p-lg { padding: var(--spacing-lg); }
.p-xl { padding: var(--spacing-xl); }
.p-0 { padding: 0; }

.m-xs { margin: var(--spacing-xs); }
.m-sm { margin: var(--spacing-sm); }
.m-md { margin: var(--spacing-md); }
.m-lg { margin: var(--spacing-lg); }
.m-0 { margin: 0; }

/* 文字 */
.text-xs { font-size: 22rpx; }
.text-sm { font-size: 24rpx; }
.text-base { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-2xl { font-size: 44rpx; }

.font-normal { font-weight: 400; }
.font-medium { font-weight: 500; }
.font-semibold { font-weight: 600; }
.font-bold { font-weight: 700; }

.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-muted { color: var(--text-muted); }
.text-center { text-align: center; }
.text-left { text-align: left; }
.text-right { text-align: right; }

/* 圆角 */
.rounded-xs { border-radius: var(--radius-xs); }
.rounded-sm { border-radius: var(--radius-sm); }
.rounded-md { border-radius: var(--radius-md); }
.rounded-lg { border-radius: var(--radius-lg); }
.rounded-xl { border-radius: var(--radius-xl); }
.rounded-full { border-radius: var(--radius-full); }

/* 阴影 */
.shadow-xs { box-shadow: var(--shadow-xs); }
.shadow-sm { box-shadow: var(--shadow-sm); }
.shadow-md { box-shadow: var(--shadow-md); }
.shadow-lg { box-shadow: var(--shadow-lg); }
.shadow-xl { box-shadow: var(--shadow-xl); }

/* 宽高 */
.w-full { width: 100%; }
.h-full { height: 100%; }

/* 溢出 */
.overflow-hidden { overflow: hidden; }
.overflow-auto { overflow: auto; }
.text-truncate {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 透明度 */
.opacity-0 { opacity: 0; }
.opacity-50 { opacity: 0.5; }
.opacity-75 { opacity: 0.75; }
.opacity-100 { opacity: 1; }

/* 定位 */
.relative { position: relative; }
.absolute { position: absolute; }
.fixed { position: fixed; }
.sticky { position: sticky; }

/* 过渡 */
.transition-all { transition: all 0.3s var(--ease-out); }
.transition-transform { transition: transform 0.3s var(--ease-out); }
.transition-opacity { transition: opacity 0.3s var(--ease-out); }

/* 隐藏/显示 */
.hidden { display: none; }
.invisible { visibility: hidden; }

/* 光标 */
.pointer-events-none { pointer-events: none; }
.pointer-events-auto { pointer-events: auto; }
