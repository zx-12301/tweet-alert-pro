<view class="page-container">
  <!-- 用户信息卡片 -->
  <view class="user-card card-gradient-blue">
    <view class="user-avatar-wrapper">
      <view class="user-avatar">U</view>
      <view class="avatar-badge"></view>
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.name || '演示用户'}}</text>
      <text class="user-email">{{userInfo.email || 'user@demo.com'}}</text>
      <view class="user-plan">
        <text class="plan-icon">💳</text>
        <text class="plan-text">{{currentPlan}}</text>
      </view>
    </view>
  </view>

  <!-- 账户信息 -->
  <view class="section">
    <text class="section-title">账户信息</text>
    <view class="info-card card">
      <view class="info-item" bindtap="editProfile">
        <view class="info-left">
          <text class="info-icon">👤</text>
          <text class="info-label">昵称</text>
        </view>
        <view class="info-right">
          <text class="info-value">{{userInfo.name || '演示用户'}}</text>
          <text class="info-arrow">›</text>
        </view>
      </view>
      
      <view class="divider"></view>
      
      <view class="info-item" bindtap="editEmail">
        <view class="info-left">
          <text class="info-icon">📧</text>
          <text class="info-label">邮箱</text>
        </view>
        <view class="info-right">
          <text class="info-value">{{userInfo.email || 'user@demo.com'}}</text>
          <text class="info-arrow">›</text>
        </view>
      </view>
      
      <view class="divider"></view>
      
      <view class="info-item" bindtap="editPhone">
        <view class="info-left">
          <text class="info-icon">📱</text>
          <text class="info-label">手机号</text>
        </view>
        <view class="info-right">
          <text class="info-value">{{userInfo.phone || '未绑定'}}</text>
          <text class="info-action {{userInfo.phone ? '' : 'add'}}">{{userInfo.phone ? '修改' : '绑定'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 账户安全 -->
  <view class="section">
    <text class="section-title">账户安全</text>
    <view class="info-card card">
      <view class="info-item" bindtap="changePassword">
        <view class="info-left">
          <text class="info-icon">🔒</text>
          <text class="info-label">修改密码</text>
        </view>
        <view class="info-right">
          <text class="info-action">修改</text>
          <text class="info-arrow">›</text>
        </view>
      </view>
      
      <view class="divider"></view>
      
      <view class="info-item" bindtap="viewLoginDevices">
        <view class="info-left">
          <text class="info-icon">📲</text>
          <text class="info-label">登录设备</text>
        </view>
        <view class="info-right">
          <text class="info-value">1 台设备</text>
          <text class="info-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 通用设置 -->
  <view class="section">
    <text class="section-title">通用设置</text>
    <view class="info-card card">
      <view class="info-item" bindtap="toggleNotifications">
        <view class="info-left">
          <text class="info-icon">🔔</text>
          <text class="info-label">通知设置</text>
        </view>
        <view class="info-right">
          <view class="switch {{notificationsEnabled ? 'on' : 'off'}}">
            <view class="switch-dot {{notificationsEnabled ? 'on' : 'off'}}"></view>
          </view>
          <text class="info-arrow">›</text>
        </view>
      </view>
      
      <view class="divider"></view>
      
      <view class="info-item" bindtap="clearCache">
        <view class="info-left">
          <text class="info-icon">🗑️</text>
          <text class="info-label">清除缓存</text>
        </view>
        <view class="info-right">
          <text class="info-value">{{cacheSize}}</text>
          <text class="info-action">清理</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 关于 -->
  <view class="section">
    <text class="section-title">关于</text>
    <view class="info-card card">
      <view class="info-item" bindtap="viewVersion">
        <view class="info-left">
          <text class="info-icon">ℹ️</text>
          <text class="info-label">当前版本</text>
        </view>
        <view class="info-right">
          <text class="info-value">1.0.0</text>
          <text class="info-arrow">›</text>
        </view>
      </view>
      
      <view class="divider"></view>
      
      <view class="info-item" bindtap="contactSupport">
        <view class="info-left">
          <text class="info-icon">💬</text>
          <text class="info-label">联系客服</text>
        </view>
        <view class="info-right">
          <text class="info-action">联系</text>
          <text class="info-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="logout">退出登录</button>
  </view>
</view>
