/* ==================== 账户页面 - 高级设计优化 ==================== */
.page-container {
  min-height: 100vh;
  background:
    linear-gradient(180deg, rgba(59, 130, 246, 0.03) 0%, rgba(139, 92, 246, 0.03) 100%),
    radial-gradient(ellipse at 50% 0%, rgba(59, 130, 246, 0.06) 0%, transparent 50%),
    linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  background-attachment: fixed;
  padding-bottom: 40rpx;
}

/* ==================== 用户卡片 ==================== */
.user-card {
  margin: 0;
  border-radius: 0 0 56rpx 56rpx;
  padding: 80rpx 32rpx 60rpx;
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 50%, #1d4ed8 100%);
  box-shadow: 0 12rpx 48rpx rgba(37, 99, 235, 0.25);
}

.user-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -30%;
  width: 150%;
  height: 150%;
  background: radial-gradient(ellipse at center, rgba(255,255,255,0.12) 0%, transparent 70%);
  pointer-events: none;
  animation: shimmerBg 10s ease-in-out infinite;
}

@keyframes shimmerBg {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  50% { transform: translate(-40rpx, 30rpx) rotate(5deg); }
}

.user-avatar-wrapper {
  position: relative;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-avatar {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.25) 0%, rgba(255, 255, 255, 0.15) 100%);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  font-weight: 800;
  color: #ffffff;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  animation: avatarFloat 4s ease-in-out infinite;
}

@keyframes avatarFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.avatar-badge {
  position: absolute;
  bottom: 8rpx;
  right: 24rpx;
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-badge::before {
  content: '';
  position: absolute;
  inset: -8rpx;
  border: 2rpx solid rgba(16, 185, 129, 0.2);
  border-radius: 50%;
  animation: badgePulse 2s ease-in-out infinite;
}

@keyframes badgePulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.15); opacity: 0; }
}

.user-info {
  text-align: center;
  margin-bottom: 24rpx;
}

.user-name {
  font-size: 44rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: -1rpx;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  background: linear-gradient(180deg, #ffffff 0%, rgba(255,255,255,0.9) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.user-email {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
  font-weight: 500;
}

.user-plan {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 28rpx;
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.25);
}

.plan-icon {
  font-size: 28rpx;
}

.plan-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 0.5rpx;
}

/* ==================== 区块 ==================== */
.section {
  padding: 32rpx 24rpx;
  margin-bottom: 8rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-muted);
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

/* ==================== 信息卡片 ==================== */
.info-card {
  background: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(226, 232, 240, 0.5);
}

.info-item {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
  overflow: hidden;
}

.info-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: linear-gradient(180deg, #3b82f6 0%, #2563eb 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.info-item:active::before {
  opacity: 1;
}

.info-item:active {
  background: linear-gradient(90deg, #eff6ff 0%, #ffffff 100%);
}

.info-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex-shrink: 0;
  z-index: 1;
}

.info-icon {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.info-item:hover .info-icon {
  transform: scale(1.1) rotate(-5deg);
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.15);
}

.info-label {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.info-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  justify-content: flex-end;
  z-index: 1;
}

.info-value {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.info-arrow {
  font-size: 36rpx;
  color: #cbd5e1;
  font-weight: 300;
  transition: all 0.3s ease;
}

.info-item:hover .info-arrow {
  color: var(--primary-color);
  transform: translateX(4rpx);
}

.info-action {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 600;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  border-radius: 16rpx;
}

.info-action.add {
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
  color: #065f46;
}

/* ==================== 分割线 ==================== */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(226, 232, 240, 0.5) 20%, transparent 100%);
  margin: 0 104rpx;
}

/* ==================== 开关 ==================== */
.switch {
  width: 100rpx;
  height: 56rpx;
  background: #e2e8f0;
  border-radius: 28rpx;
  position: relative;
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  display: flex;
  align-items: center;
  padding: 6rpx;
}

.switch.on {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
}

.switch-dot {
  width: 44rpx;
  height: 44rpx;
  background: #ffffff;
  border-radius: 22rpx;
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.switch.on .switch-dot {
  transform: translateX(44rpx);
}

.switch-dot.off {
  transform: translateX(0);
}

/* ==================== 退出登录 ==================== */
.logout-section {
  padding: 32rpx 24rpx 40rpx;
}

.logout-btn {
  width: 100%;
  padding: 36rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #ef4444;
  background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
  border: 2rpx solid rgba(239, 68, 68, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(239, 68, 68, 0.15);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.logout-btn:active {
  transform: scale(0.96);
  background: linear-gradient(135deg, #fecaca 0%, #fca5a5 100%);
  box-shadow: 0 2rpx 8rpx rgba(239, 68, 68, 0.1);
}

/* ==================== 页面进入动画 ==================== */
.page-enter {
  animation: pageEnter 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes pageEnter {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ==================== 安全区域 ==================== */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
