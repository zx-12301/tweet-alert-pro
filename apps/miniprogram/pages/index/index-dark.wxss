/* ==========================================================================
   首页 - 深色主题设计
   100% 还原设计图
   ========================================================================== */

page {
  background: #0d1117;
  min-height: 100vh;
}

.dark-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0d1117 0%, #161b22 100%);
  padding: 0 0 140rpx;
}

/* ==========================================================================
   顶部标签
   ========================================================================== */

.top-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 16rpx 0;
  margin-bottom: 24rpx;
}

.badge-dot {
  width: 8rpx;
  height: 8rpx;
  background: #238636;
  border-radius: 50%;
  box-shadow: 0 0 12rpx #238636;
}

.top-badge text {
  font-size: 22rpx;
  color: #8b949e;
  font-weight: 400;
}

/* ==========================================================================
   主标题区域
   ========================================================================== */

.hero-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx 48rpx;
  text-align: center;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.hero-highlight {
  font-size: 40rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #58a6ff 0%, #1f6feb 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1.4;
  margin-bottom: 24rpx;
}

.hero-desc {
  font-size: 24rpx;
  color: #8b949e;
  line-height: 1.6;
  max-width: 600rpx;
}

/* ==========================================================================
   统计卡片
   ========================================================================== */

.stats-card {
  display: flex;
  align-items: center;
  margin: 0 24rpx 40rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, rgba(56, 139, 253, 0.1) 0%, rgba(22, 27, 34, 0.8) 100%);
  border: 1rpx solid rgba(56, 139, 253, 0.2);
  border-radius: 24rpx;
  backdrop-filter: blur(20rpx);
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.stat-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  background: rgba(56, 139, 253, 0.15);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stat-icon {
  font-size: 40rpx;
}

.stat-content {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #8b949e;
}

.stat-divider {
  width: 1rpx;
  height: 64rpx;
  background: rgba(139, 148, 158, 0.2);
  margin: 0 32rpx;
}

/* ==========================================================================
   快捷操作
   ========================================================================== */

.quick-actions-section {
  padding: 0 24rpx 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.section-link {
  font-size: 24rpx;
  color: #58a6ff;
  font-weight: 500;
}

.action-cards {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.action-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 20rpx;
  background: rgba(22, 27, 34, 0.8);
  border: 1rpx solid rgba(139, 148, 158, 0.1);
  border-radius: 24rpx;
  gap: 16rpx;
  transition: all 0.2s ease;
}

.action-card:active {
  transform: scale(0.95);
}

.action-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 300;
  color: #ffffff;
}

/* 卡片颜色 */
.card-blue .action-icon {
  background: linear-gradient(135deg, #1f6feb 0%, #0d419d 100%);
  box-shadow: 0 8rpx 24rpx rgba(31, 111, 235, 0.3);
}

.card-purple .action-icon {
  background: linear-gradient(135deg, #8957e5 0%, #5a31a8 100%);
  box-shadow: 0 8rpx 24rpx rgba(137, 87, 229, 0.3);
}

.card-orange .action-icon {
  background: linear-gradient(135deg, #d29922 0%, #9e6f0b 100%);
  box-shadow: 0 8rpx 24rpx rgba(210, 153, 34, 0.3);
}

.card-green .action-icon {
  background: linear-gradient(135deg, #238636 0%, #0e4429 100%);
  box-shadow: 0 8rpx 24rpx rgba(35, 134, 54, 0.3);
}

.action-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
  text-align: center;
}

.action-desc {
  font-size: 22rpx;
  color: #8b949e;
  text-align: center;
}

/* ==========================================================================
   最近通知
   ========================================================================== */

.notifications-section {
  padding: 0 24rpx;
}

.notification-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.notification-card {
  padding: 28rpx;
  background: rgba(22, 27, 34, 0.6);
  border: 1rpx solid rgba(139, 148, 158, 0.1);
  border-radius: 20rpx;
  position: relative;
  transition: all 0.2s ease;
}

.notification-card:active {
  background: rgba(22, 27, 34, 0.8);
  border-color: rgba(56, 139, 253, 0.3);
}

.notification-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.notification-handle {
  font-size: 26rpx;
  font-weight: 600;
  color: #58a6ff;
}

.notification-time {
  font-size: 22rpx;
  color: #8b949e;
}

.notification-content {
  display: block;
  font-size: 28rpx;
  color: #c9d1d9;
  line-height: 1.5;
}

.notification-dot {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  width: 12rpx;
  height: 12rpx;
  background: #58a6ff;
  border-radius: 50%;
  box-shadow: 0 0 12rpx #58a6ff;
}

.empty-state {
  padding: 60rpx 40rpx;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #8b949e;
}

/* ==========================================================================
   安全区域
   ========================================================================== */

.tabbar-safe-area {
  height: 140rpx;
  flex-shrink: 0;
}
