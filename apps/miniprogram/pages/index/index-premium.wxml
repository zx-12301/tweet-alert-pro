<view class="page-container animate-fade-in">
  <!-- 极简头部 - 无渐变无光晕 -->
  <view class="header-section">
    <view class="header-content">
      <text class="premium-h1">{{greetingText}}</text>
      <text class="premium-caption header-subtitle">实时监控 Twitter 动态</text>
    </view>
    
    <!-- 统计卡片 - 极简设计 -->
    <view class="stats-row">
      <view class="stat-card-minimal">
        <text class="stat-value">{{stats.totalTasks}}</text>
        <text class="stat-label">监控任务</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-card-minimal">
        <text class="stat-value">{{stats.todayNotifications}}</text>
        <text class="stat-label">今日通知</text>
      </view>
    </view>
  </view>

  <!-- 快捷操作 - 无边框卡片 -->
  <view class="section">
    <text class="premium-h2 section-title">快捷操作</text>
    
    <view class="action-grid-minimal">
      <view class="action-item-minimal" bindtap="createTask">
        <view class="action-icon-minimal action-icon-blue">
          <text>+</text>
        </view>
        <text class="action-label">创建任务</text>
      </view>
      
      <view class="action-item-minimal" bindtap="viewSubscription">
        <view class="action-icon-minimal action-icon-purple">
          <text>◆</text>
        </view>
        <text class="action-label">订阅管理</text>
      </view>
      
      <view class="action-item-minimal" bindtap="viewSettings">
        <view class="action-icon-minimal action-icon-gray">
          <text>⚙</text>
        </view>
        <text class="action-label">功能配置</text>
      </view>
      
      <view class="action-item-minimal" bindtap="viewHelp">
        <view class="action-icon-minimal action-icon-green">
          <text>?</text>
        </view>
        <text class="action-label">使用帮助</text>
      </view>
    </view>
  </view>

  <!-- 最近通知 - 列表 -->
  <view class="section">
    <view class="section-header-minimal">
      <text class="premium-h2">最近通知</text>
      <text class="section-link" bindtap="viewAllNotifications">查看全部</text>
    </view>
    
    <view wx:if="{{notifications.length === 0}}" class="empty-state-minimal">
      <text class="empty-icon-minimal">📭</text>
      <text class="empty-text-minimal">暂无新通知</text>
    </view>
    
    <view wx:else class="notification-list-minimal">
      <view wx:for="{{notifications}}" wx:key="id" class="notification-item-minimal" bindtap="viewNotificationDetail" data-id="{{item.id}}">
        <view class="notification-avatar-minimal">@{{item.twitterHandle}}</view>
        <view class="notification-content-minimal">
          <text class="notification-text-minimal">{{item.tweetContent}}</text>
          <text class="notification-time-minimal">{{item.createdAt}}</text>
        </view>
        <view wx:if="{{!item.read}}" class="notification-dot-minimal"></view>
      </view>
    </view>
  </view>
  
  <!-- 底部安全区域 -->
  <view class="tabbar-safe-area"></view>
</view>
