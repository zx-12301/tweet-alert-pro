/* ==========================================================================
   首页 - Premium Design
   苹果风格极简主义
   ========================================================================== */

/* 引入全局设计系统 */
@import '../../styles/premium.css';

.page-container {
  min-height: 100vh;
  background-color: var(--bg);
  padding: 0;
}

/* ==========================================================================
   头部区域 - 无边框无渐变
   ========================================================================== */

.header-section {
  background: var(--surface);
  padding: var(--space-2xl) var(--space-lg) var(--space-xl);
  border-bottom: 1rpx solid var(--border);
}

.header-content {
  margin-bottom: var(--space-xl);
}

.header-subtitle {
  display: block;
  margin-top: var(--space-sm);
  color: var(--text-tertiary);
}

/* 统计行 - 极简设计 */
.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: var(--space-lg) 0;
}

.stat-card-minimal {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-xs);
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -1rpx;
}

.stat-label {
  font-size: var(--tiny-size);
  color: var(--text-tertiary);
  font-weight: 400;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: var(--border);
}

/* ==========================================================================
   区块通用
   ========================================================================== */

.section {
  padding: var(--space-xl) var(--space-lg);
}

.section-title {
  display: block;
  margin-bottom: var(--space-lg);
}

.section-header-minimal {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-lg);
}

.section-link {
  font-size: var(--caption-size);
  color: var(--accent);
  font-weight: 500;
}

/* ==========================================================================
   快捷操作 - 无边框极简图标
   ========================================================================== */

.action-grid-minimal {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-md);
}

.action-item-minimal {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-md) 0;
  transition: transform 0.2s var(--ease-standard);
}

.action-item-minimal:active {
  transform: scale(0.92);
}

.action-icon-minimal {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-2xl);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 300;
  color: #ffffff;
  transition: all 0.3s var(--ease-standard);
}

/* 低饱和色彩 */
.action-icon-blue {
  background: linear-gradient(135deg, #5e60ce 0%, #4a4cb8 100%);
  box-shadow: 0 8rpx 24rpx rgba(94, 96, 206, 0.2);
}

.action-icon-purple {
  background: linear-gradient(135deg, #7b7dd6 0%, #6a6cc4 100%);
  box-shadow: 0 8rpx 24rpx rgba(123, 125, 214, 0.2);
}

.action-icon-gray {
  background: linear-gradient(135deg, #6e6e73 0%, #5a5a5e 100%);
  box-shadow: 0 8rpx 24rpx rgba(110, 110, 115, 0.2);
}

.action-icon-green {
  background: linear-gradient(135deg, #34c759 0%, #28a745 100%);
  box-shadow: 0 8rpx 24rpx rgba(52, 199, 89, 0.2);
}

.action-label {
  font-size: var(--tiny-size);
  color: var(--text-secondary);
  font-weight: 400;
  text-align: center;
}

/* ==========================================================================
   通知列表 - 极简卡片
   ========================================================================== */

.notification-list-minimal {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.notification-item-minimal {
  display: flex;
  align-items: flex-start;
  gap: var(--space-md);
  padding: var(--space-lg);
  background: var(--surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-xs);
  transition: all 0.2s var(--ease-standard);
  position: relative;
}

.notification-item-minimal:active {
  background: var(--bg-secondary);
  box-shadow: var(--shadow-xs);
}

.notification-avatar-minimal {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-full);
  background: var(--bg-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.notification-content-minimal {
  flex: 1;
  min-width: 0;
}

.notification-text-minimal {
  display: block;
  font-size: var(--body-size);
  color: var(--text-primary);
  line-height: 1.5;
  margin-bottom: var(--space-xs);
  
  /* 多行省略 */
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.notification-time-minimal {
  display: block;
  font-size: var(--tiny-size);
  color: var(--text-tertiary);
}

.notification-dot-minimal {
  position: absolute;
  top: var(--space-lg);
  right: var(--space-lg);
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 0 4rpx var(--info-bg);
}

/* 空状态 - 极简 */
.empty-state-minimal {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-3xl) var(--space-lg);
  text-align: center;
}

.empty-icon-minimal {
  font-size: 80rpx;
  margin-bottom: var(--space-lg);
  opacity: 0.3;
}

.empty-text-minimal {
  font-size: var(--caption-size);
  color: var(--text-tertiary);
}

/* ==========================================================================
   响应式优化
   ========================================================================== */

@media (min-width: 768px) {
  .action-grid-minimal {
    gap: var(--space-lg);
  }
  
  .action-icon-minimal {
    width: 100rpx;
    height: 100rpx;
    font-size: 48rpx;
  }
}
