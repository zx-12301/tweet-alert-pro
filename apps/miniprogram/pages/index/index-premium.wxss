/* ==========================================================================
   首页 - Premium Design
   苹果风格极简主义
   ========================================================================== */

/* 设计令牌 - 内联定义 */
page {
  --primary: #1a1a2e;
  --primary-light: #2d2d44;
  --accent: #5e60ce;
  --bg: #faf9f8;
  --bg-secondary: #f5f4f2;
  --surface: #ffffff;
  --text-primary: #1a1a2e;
  --text-secondary: #6e6e73;
  --text-tertiary: #a1a1a6;
  --border: rgba(0, 0, 0, 0.06);
  --shadow-xs: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-sm: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  --radius-lg: 20rpx;
  --radius-xl: 28rpx;
  --radius-2xl: 40rpx;
  --radius-full: 9999rpx;
  --space-xs: 4rpx;
  --space-sm: 8rpx;
  --space-md: 16rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;
  --space-2xl: 64rpx;
  --space-3xl: 96rpx;
  --h1-size: 44rpx;
  --h2-size: 34rpx;
  --body-size: 28rpx;
  --caption-size: 24rpx;
  --tiny-size: 22rpx;
  --ease-standard: cubic-bezier(0.4, 0.0, 0.2, 1);
}

.page-container {
  min-height: 100vh;
  background-color: var(--bg);
  padding: 0;
}

.header-section {
  background: var(--surface);
  padding: var(--space-2xl) var(--space-lg) var(--space-xl);
  border-bottom: 1rpx solid var(--border);
}

.header-content {
  margin-bottom: var(--space-xl);
}

.header-subtitle {
  display: block;
  margin-top: var(--space-sm);
  color: var(--text-tertiary);
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: var(--space-lg) 0;
}

.stat-card-minimal {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-xs);
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -1rpx;
}

.stat-label {
  font-size: var(--tiny-size);
  color: var(--text-tertiary);
  font-weight: 400;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: var(--border);
}

.section {
  padding: var(--space-xl) var(--space-lg);
}

.section-title {
  display: block;
  margin-bottom: var(--space-lg);
}

.section-header-minimal {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-lg);
}

.section-link {
  font-size: var(--caption-size);
  color: var(--accent);
  font-weight: 500;
}

.action-grid-minimal {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-md);
}

.action-item-minimal {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-md) 0;
  transition: transform 0.2s var(--ease-standard);
}

.action-item-minimal:active {
  transform: scale(0.92);
}

.action-icon-minimal {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-2xl);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 300;
  color: #ffffff;
}

.action-icon-blue {
  background: linear-gradient(135deg, #5e60ce 0%, #4a4cb8 100%);
  box-shadow: 0 8rpx 24rpx rgba(94, 96, 206, 0.2);
}

.action-icon-purple {
  background: linear-gradient(135deg, #7b7dd6 0%, #6a6cc4 100%);
  box-shadow: 0 8rpx 24rpx rgba(123, 125, 214, 0.2);
}

.action-icon-gray {
  background: linear-gradient(135deg, #6e6e73 0%, #5a5a5e 100%);
  box-shadow: 0 8rpx 24rpx rgba(110, 110, 115, 0.2);
}

.action-icon-green {
  background: linear-gradient(135deg, #34c759 0%, #28a745 100%);
  box-shadow: 0 8rpx 24rpx rgba(52, 199, 89, 0.2);
}

.action-label {
  font-size: var(--tiny-size);
  color: var(--text-secondary);
  font-weight: 400;
  text-align: center;
}

.notification-list-minimal {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.notification-item-minimal {
  display: flex;
  align-items: flex-start;
  gap: var(--space-md);
  padding: var(--space-lg);
  background: var(--surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-xs);
  transition: all 0.2s var(--ease-standard);
  position: relative;
}

.notification-item-minimal:active {
  background: var(--bg-secondary);
}

.notification-avatar-minimal {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-full);
  background: var(--bg-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.notification-content-minimal {
  flex: 1;
  min-width: 0;
}

.notification-text-minimal {
  display: block;
  font-size: var(--body-size);
  color: var(--text-primary);
  line-height: 1.5;
  margin-bottom: var(--space-xs);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.notification-time-minimal {
  display: block;
  font-size: var(--tiny-size);
  color: var(--text-tertiary);
}

.notification-dot-minimal {
  position: absolute;
  top: var(--space-lg);
  right: var(--space-lg);
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 0 4rpx rgba(0, 122, 255, 0.1);
}

.empty-state-minimal {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-3xl) var(--space-lg);
  text-align: center;
}

.empty-icon-minimal {
  font-size: 80rpx;
  margin-bottom: var(--space-lg);
  opacity: 0.3;
}

.empty-text-minimal {
  font-size: var(--caption-size);
  color: var(--text-tertiary);
}

.tabbar-safe-area {
  height: 140rpx;
  flex-shrink: 0;
}

.animate-fade-in {
  animation: fadeIn 0.4s var(--ease-standard);
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
