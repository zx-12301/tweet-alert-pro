<view class="dark-page">
  <!-- 主滚动区域 -->
  <scroll-view class="main-scroll" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
    
    <!-- 顶部标签 -->
    <view class="top-badge">
      <view class="badge-dot"></view>
      <text>7×24 小时实时监控</text>
    </view>

    <!-- 主标题区域 -->
    <view class="hero-section">
      <text class="hero-title">当关注的用户发推时</text>
      <text class="hero-highlight">第一时间通知你</text>
      <text class="hero-desc">智能监控 Twitter 账号动态，支持语音电话、邮件、微信等多种通知方式，让你不错过任何重要信息</text>
    </view>

    <!-- 统计卡片 -->
    <view class="stats-card">
      <view class="stat-item">
        <view class="stat-icon-box">
          <text class="stat-icon">📋</text>
        </view>
        <view class="stat-content">
          <text class="stat-value">{{stats.totalTasks}}</text>
          <text class="stat-label">监控任务</text>
        </view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-icon-box">
          <text class="stat-icon">📧</text>
        </view>
        <view class="stat-content">
          <text class="stat-value">{{stats.todayNotifications}}</text>
          <text class="stat-label">今日通知</text>
        </view>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="quick-actions-section">
      <view class="section-header">
        <view class="title-wrapper">
          <text class="section-title">快捷操作</text>
          <view class="title-accent"></view>
        </view>
        <text class="section-link" bindtap="viewAll">查看全部 ›</text>
      </view>
      
      <view class="action-grid">
        <view class="action-card" bindtap="createTask">
          <view class="action-icon-box icon-blue">
            <text>+</text>
          </view>
          <text class="action-name">创建任务</text>
          <text class="action-subtitle">新建监控</text>
        </view>
        
        <view class="action-card" bindtap="viewSubscription">
          <view class="action-icon-box icon-purple">
            <text>◆</text>
          </view>
          <text class="action-name">订阅管理</text>
          <text class="action-subtitle">查看用量</text>
        </view>
        
        <view class="action-card" bindtap="viewSettings">
          <view class="action-icon-box icon-orange">
            <text>⚙</text>
          </view>
          <text class="action-name">功能配置</text>
          <text class="action-subtitle">API 设置</text>
        </view>
        
        <view class="action-card" bindtap="viewHelp">
          <view class="action-icon-box icon-green">
            <text>?</text>
          </view>
          <text class="action-name">使用帮助</text>
          <text class="action-subtitle">常见问题</text>
        </view>
      </view>
    </view>

    <!-- 最近通知 -->
    <view class="notifications-section">
      <view class="section-header">
        <view class="title-wrapper">
          <text class="section-title">最近通知</text>
          <view class="title-accent"></view>
        </view>
        <text class="section-link" bindtap="viewAllNotifications">全部 ›</text>
      </view>
      
      <view wx:if="{{notifications.length === 0}}" class="empty-state">
        <text class="empty-text">暂无新通知</text>
      </view>
      
      <view wx:else class="notification-list">
        <view wx:for="{{notifications}}" wx:key="id" class="notification-card" bindtap="viewNotificationDetail" data-id="{{item.id}}">
          <view class="notification-header">
            <view class="tag-wrapper">
              <text class="notification-tag">{{item.twitterHandle}}</text>
              <text class="notification-time">{{item.createdAt}}</text>
            </view>
          </view>
          <text class="notification-content">{{item.tweetContent}}</text>
          <view wx:if="{{!item.read}}" class="notification-dot"></view>
        </view>
      </view>
    </view>
    
    <!-- 底部占位，防止内容被导航栏遮挡 -->
    <view class="bottom-spacer"></view>
  </scroll-view>

  <!-- 底部导航栏 -->
  <view class="bottom-nav">
    <view class="nav-item {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">
      <text class="nav-icon">🏠</text>
      <text class="nav-label">首页</text>
    </view>
    <view class="nav-item {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">
      <text class="nav-icon">📋</text>
      <text class="nav-label">任务</text>
    </view>
    <view class="nav-item {{currentTab === 2 ? 'active' : ''}}" bindtap="switchTab" data-index="2">
      <text class="nav-icon">💳</text>
      <text class="nav-label">订阅</text>
    </view>
    <view class="nav-item {{currentTab === 3 ? 'active' : ''}}" bindtap="switchTab" data-index="3">
      <text class="nav-icon">👤</text>
      <text class="nav-label">设置</text>
    </view>
  </view>
</view>
