/* ==========================================================================
   首页 - Figma 设计 100% 还原
   深色主题
   ========================================================================== */

page {
  background: #0B1120;
  min-height: 100vh;
}

.dark-page {
  min-height: 100vh;
  background: #0B1120;
  position: relative;
  overflow: hidden;
  height: 100vh;
}

/* 主滚动区域 */
.main-scroll {
  height: 100vh;
  box-sizing: border-box;
}

/* 顶部安全区域（适配刘海屏） */
.top-safe-area {
  height: calc(88rpx + env(safe-area-inset-top));
  flex-shrink: 0;
}

/* ==========================================================================
   顶部标签
   ========================================================================== */

.top-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 20rpx;
  margin-top: 20rpx;
}

.badge-dot {
  width: 6rpx;
  height: 6rpx;
  background: #34d399;
  border-radius: 50%;
  box-shadow: 0 0 12rpx rgba(52, 211, 153, 0.8);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.top-badge text {
  font-size: 22rpx;
  color: #cbd5e1;
  font-weight: 500;
}

/* ==========================================================================
   主标题区域
   ========================================================================== */

.hero-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx 32rpx;
  text-align: center;
  position: relative;
  z-index: 10;
}

.top-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  margin-bottom: 32rpx;
}

.badge-dot {
  width: 8rpx;
  height: 8rpx;
  background: #10b981;
  border-radius: 50%;
  box-shadow: 0 0 12rpx rgba(16, 185, 129, 0.6);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.top-badge text {
  font-size: 20rpx;
  color: #cbd5e1;
  font-weight: 500;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.3;
  margin-bottom: 8rpx;
  letter-spacing: -0.5rpx;
}

.hero-highlight {
  font-size: 44rpx;
  font-weight: 700;
  background: linear-gradient(to right, #3b82f6, #60a5fa);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1.3;
  margin-bottom: 20rpx;
  display: block;
}

.hero-desc {
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.6;
  max-width: 520rpx;
}

/* ==========================================================================
   统计卡片（2 列网格）
   ========================================================================== */

.stats-grid-new {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 24rpx 40rpx;
}

.stat-card-new {
  background: #121A2F;
  border-radius: 28rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
  position: relative;
  overflow: hidden;
}

.stat-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.stat-card-title {
  font-size: 20rpx;
  font-weight: 500;
  color: #94a3b8;
}

.stat-icon-box {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.icon-blue {
  background: rgba(59, 130, 246, 0.1);
  border-color: rgba(59, 130, 246, 0.2);
}

.icon-orange {
  background: rgba(245, 158, 11, 0.1);
  border-color: rgba(245, 158, 11, 0.2);
}

.stat-card-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -1rpx;
}

/* 背景光晕 */
.stat-card-new::after {
  content: '';
  position: absolute;
  bottom: -48rpx;
  right: -48rpx;
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  filter: blur(64rpx);
  opacity: 0.15;
}

.stat-blue::after {
  background: rgba(59, 130, 246, 0.3);
}

.stat-orange::after {
  background: rgba(245, 158, 11, 0.3);
}

/* ==========================================================================
   快捷操作
   ========================================================================== */

.quick-actions-section {
  padding: 0 40rpx 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 24rpx;
}

.title-wrapper {
  position: relative;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  position: relative;
  z-index: 10;
}

.title-accent {
  position: absolute;
  bottom: -4rpx;
  left: 0;
  width: 40rpx;
  height: 6rpx;
  background: rgba(59, 130, 246, 0.3);
  border-radius: 8rpx;
}

.section-link {
  font-size: 24rpx;
  color: #60a5fa;
  font-weight: 500;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.action-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #121A2F;
  border-radius: 32rpx;
  gap: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
  transition: all 0.2s ease;
}

.action-card:active {
  transform: scale(0.95);
  background: #1A243D;
}

.action-icon-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #ffffff;
  margin-bottom: 4rpx;
}

.icon-blue {
  background: rgba(59, 130, 246, 0.1);
  border: 1rpx solid rgba(59, 130, 246, 0.2);
}

.icon-purple {
  background: rgba(139, 92, 246, 0.1);
  border: 1rpx solid rgba(139, 92, 246, 0.2);
}

.icon-orange {
  background: rgba(245, 158, 11, 0.1);
  border: 1rpx solid rgba(245, 158, 11, 0.2);
}

.icon-green {
  background: rgba(16, 185, 129, 0.1);
  border: 1rpx solid rgba(16, 185, 129, 0.2);
}

.action-name {
  font-size: 22rpx;
  font-weight: 600;
  color: #e2e8f0;
  text-align: center;
}

.action-subtitle {
  font-size: 18rpx;
  color: #64748b;
  font-weight: 500;
  text-align: center;
}

/* ==========================================================================
   最近通知
   ========================================================================== */

.notifications-section {
  padding: 0 40rpx 40rpx;
}

.notification-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.notification-card {
  padding: 32rpx;
  background: #121A2F;
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
  position: relative;
  transition: all 0.2s ease;
}

.notification-card:active {
  border-color: rgba(59, 130, 246, 0.3);
}

.notification-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.tag-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.notification-tag {
  background: rgba(59, 130, 246, 0.1);
  color: #60a5fa;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  border: 1rpx solid rgba(59, 130, 246, 0.2);
}

.notification-time {
  font-size: 20rpx;
  color: #64748b;
  font-weight: 500;
}

.notification-content {
  display: block;
  font-size: 24rpx;
  color: #cbd5e1;
  line-height: 1.5;
  font-weight: 500;
}

.notification-dot {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  width: 16rpx;
  height: 16rpx;
  background: #3b82f6;
  border-radius: 50%;
  box-shadow: 0 0 16rpx rgba(59, 130, 246, 0.5);
}

.empty-state {
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-text {
  font-size: 24rpx;
  color: #64748b;
}

/* 底部占位（适配 tabBar 高度） */
.bottom-spacer {
  height: calc(98rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}
