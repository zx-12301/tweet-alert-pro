.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f9ff 0%, #f8fafc 100%);
}

/* 头部区域 */
.header-section {
  margin: 0;
  border-radius: 0 0 40rpx 40rpx;
  padding: 0;
  overflow: hidden;
  position: relative;
}

.header-section::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  pointer-events: none;
}

.header-content {
  padding: 60rpx 32rpx 48rpx;
  position: relative;
  z-index: 1;
}

.welcome-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.welcome-greeting {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -1rpx;
}

.welcome-emoji {
  font-size: 48rpx;
  margin-left: 12rpx;
  animation: wave 2s ease-in-out infinite;
}

@keyframes wave {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(15deg); }
  75% { transform: rotate(-15deg); }
}

.welcome-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.5;
  display: block;
  margin-bottom: 40rpx;
}

/* 头部统计 */
.header-stats {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.header-stat-item {
  display: flex;
  align-items: center;
  flex: 1;
}

.stat-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.stat-icon {
  font-size: 40rpx;
}

.stat-info {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
}

.stat-divider-vertical {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
  margin: 0 20rpx;
}

/* 区块 */
.section {
  padding: 32rpx 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.section-more {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 500;
}

/* 快捷操作网格 */
.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.action-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 16rpx;
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1rpx solid rgba(226, 232, 240, 0.5);
}

.action-card:active {
  transform: translateY(-4rpx) scale(0.96);
  box-shadow: var(--shadow-lg);
}

.action-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  font-size: 44rpx;
}

.action-icon-blue {
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
}

.action-icon-purple {
  background: linear-gradient(135deg, #ede9fe 0%, #ddd6fe 100%);
}

.action-icon-orange {
  background: linear-gradient(135deg, #ffedd5 0%, #fed7aa 100%);
}

.action-icon-green {
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
}

.action-text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.action-desc {
  font-size: 20rpx;
  color: var(--text-muted);
}

/* 通知列表 */
.notification-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.notification-item {
  display: flex;
  align-items: flex-start;
  padding: 28rpx;
  margin-bottom: 0;
  transition: all 0.2s ease;
  position: relative;
}

.notification-item:active {
  background: linear-gradient(90deg, #eff6ff 0%, #ffffff 100%);
}

.notification-avatar {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--primary-color);
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.notification-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.notification-text {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.notification-time {
  font-size: 22rpx;
  color: var(--text-muted);
}

.notification-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--primary-color);
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 24rpx;
  box-shadow: 0 0 12rpx rgba(37, 99, 235, 0.5);
}

/* 空状态小 */
.empty-state-small {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
}

.empty-icon-small {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text-small {
  font-size: 28rpx;
  color: var(--text-muted);
}

/* 安全区域 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
