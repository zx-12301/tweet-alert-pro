<view class="page-container animate-fade-in">
  <!-- 极简头部 -->
  <view class="header-section">
    <view class="header-content">
      <text class="premium-h1">通知历史</text>
      <text class="premium-caption header-subtitle">{{stats.total}} 条通知</text>
    </view>
    
    <!-- 统计行 -->
    <view class="stats-row">
      <view class="stat-card-minimal">
        <text class="stat-value">{{stats.today}}</text>
        <text class="stat-label">今日</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-card-minimal">
        <text class="stat-value">{{stats.unread}}</text>
        <text class="stat-label">未读</text>
      </view>
    </view>
  </view>

  <!-- 筛选器 -->
  <view class="section">
    <view class="filter-row-minimal">
      <view class="filter-pill-minimal {{filterType === 'all' ? 'active' : ''}}" bindtap="setFilter" data-type="all">
        <text>全部</text>
      </view>
      <view class="filter-pill-minimal {{filterType === 'unread' ? 'active' : ''}}" bindtap="setFilter" data-type="unread">
        <text>未读</text>
      </view>
      <view class="filter-pill-minimal {{filterType === 'today' ? 'active' : ''}}" bindtap="setFilter" data-type="today">
        <text>今天</text>
      </view>
      <view class="filter-pill-minimal {{filterType === 'week' ? 'active' : ''}}" bindtap="setFilter" data-type="week">
        <text>本周</text>
      </view>
    </view>
  </view>

  <!-- 通知列表 - 分组显示 -->
  <view wx:if="{{groupedNotifications.length > 0}}" class="section">
    <view class="notification-grouped-list">
      <view wx:for="{{groupedNotifications}}" wx:key="date" class="notification-group">
        <text class="group-date-label">{{item.date}}</text>
        
        <view class="notification-list-minimal">
          <view wx:for="{{item.notifications}}" wx:key="id" wx:for-item="notif" wx:for-index="notifIndex" 
                class="notification-item-minimal {{!notif.read ? 'unread' : ''}}" 
                bindtap="viewNotificationDetail" 
                data-id="{{notif.id}}">
            <view class="notification-avatar-minimal">@{{notif.twitterHandle}}</view>
            <view class="notification-content-minimal">
              <text class="notification-text-minimal">{{notif.tweetContent}}</text>
              <text class="notification-time-minimal">{{notif.createdAt}}</text>
            </view>
            <view wx:if="{{!notif.read}}" class="notification-dot-minimal"></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty-section-minimal">
    <view class="empty-illustration-minimal">
      <text class="empty-icon-premium">📭</text>
    </view>
    <text class="empty-title-premium">暂无通知</text>
    <text class="empty-desc-premium">创建监控任务后，新通知会显示在这里</text>
    <button class="premium-btn premium-btn-primary" bindtap="createTask">创建任务</button>
  </view>
  
  <!-- 底部安全区域 -->
  <view class="tabbar-safe-area"></view>
</view>
