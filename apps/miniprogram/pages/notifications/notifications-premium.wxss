/* ==========================================================================
   通知页面 - Premium Design
   分组列表设计
   ========================================================================== */

.page-container {
  min-height: 100vh;
  background-color: var(--bg);
}

/* ==========================================================================
   分组列表
   ========================================================================== */

.notification-grouped-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-lg);
}

.notification-group {
  display: flex;
  flex-direction: column;
}

.group-date-label {
  display: block;
  font-size: var(--caption-size);
  font-weight: 600;
  color: var(--text-tertiary);
  margin-bottom: var(--space-sm);
  padding-left: var(--space-sm);
}

/* 通知列表 */
.notification-list-minimal {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.notification-item-minimal {
  display: flex;
  align-items: flex-start;
  gap: var(--space-md);
  padding: var(--space-lg);
  background: var(--surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-xs);
  transition: all 0.2s var(--ease-standard);
  position: relative;
  border: 1rpx solid transparent;
}

.notification-item-minimal:active {
  background: var(--bg-secondary);
  box-shadow: var(--shadow-xs);
}

.notification-item-minimal.unread {
  border-color: var(--accent);
  background: linear-gradient(90deg, var(--info-bg) 0%, var(--surface) 100%);
}

.notification-avatar-minimal {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-full);
  background: var(--bg-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.notification-content-minimal {
  flex: 1;
  min-width: 0;
}

.notification-text-minimal {
  display: block;
  font-size: var(--body-size);
  color: var(--text-primary);
  line-height: 1.5;
  margin-bottom: var(--space-xs);
  
  /* 多行省略 */
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.notification-time-minimal {
  display: block;
  font-size: var(--tiny-size);
  color: var(--text-tertiary);
}

.notification-dot-minimal {
  position: absolute;
  top: var(--space-lg);
  right: var(--space-lg);
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 0 4rpx var(--info-bg);
}

.notification-item-minimal.unread .notification-dot-minimal {
  box-shadow: 0 0 0 4rpx rgba(94, 96, 206, 0.1);
}

/* ==========================================================================
   空状态
   ========================================================================== */

.empty-section-minimal {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-3xl) var(--space-lg);
  text-align: center;
}

.empty-illustration-minimal {
  margin-bottom: var(--space-xl);
}

.empty-icon-premium {
  font-size: 100rpx;
  opacity: 0.3;
  display: block;
}

.empty-title-premium {
  font-size: var(--h2-size);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
  display: block;
}

.empty-desc-premium {
  font-size: var(--caption-size);
  color: var(--text-tertiary);
  line-height: 1.6;
  margin-bottom: var(--space-2xl);
  display: block;
}

/* ==========================================================================
   响应式优化
   ========================================================================== */

@media (min-width: 768px) {
  .notification-item-minimal {
    padding: var(--space-xl);
  }
  
  .notification-avatar-minimal {
    width: 88rpx;
    height: 88rpx;
  }
}
