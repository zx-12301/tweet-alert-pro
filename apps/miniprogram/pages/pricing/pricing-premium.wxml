<view class="premium-container page-enter">
  <!-- 极简头部 -->
  <view class="premium-header">
    <view class="header-content">
      <text class="page-title">订阅计划</text>
      <text class="page-subtitle">选择适合您的方案，随时取消</text>
    </view>

    <!-- 信任标签 -->
    <view class="trust-badges">
      <view class="trust-badge">
        <text class="trust-icon">✓</text>
        <text class="trust-text">7天退款</text>
      </view>
      <view class="trust-badge">
        <text class="trust-icon">✓</text>
        <text class="trust-text">随时取消</text>
      </view>
      <view class="trust-badge">
        <text class="trust-icon">✓</text>
        <text class="trust-text">安全支付</text>
      </view>
    </view>
  </view>

  <!-- 计划卡片 - 极简设计 -->
  <view class="plans-section">
    <view wx:for="{{plans}}" wx:key="id" class="plan-card-premium {{item.popular ? 'featured' : ''}}" bindtap="selectPlan" data-plan="{{item}}">
      <!-- 热门标签 -->
      <view wx:if="{{item.popular}}" class="popular-tag">
        <text class="popular-tag-text">推荐</text>
      </view>

      <!-- 计划名称 -->
      <view class="plan-header-premium">
        <text class="plan-name-premium">{{item.name}}</text>
        <text wx:if="{{item.tag}}" class="plan-tag-premium">{{item.tag}}</text>
      </view>

      <!-- 价格 -->
      <view class="plan-price-premium">
        <text class="price-symbol">¥</text>
        <text class="price-value-premium">{{item.price}}</text>
        <text class="price-period">/{{item.period}}</text>
      </view>

      <!-- 功能列表 -->
      <view class="plan-features-premium">
        <view wx:for="{{item.features}}" wx:key="*this" wx:for-item="feature" class="feature-row-premium">
          <text class="feature-check">✓</text>
          <text class="feature-text-premium">{{feature}}</text>
        </view>
      </view>

      <!-- 选择按钮 -->
      <button class="plan-btn-premium {{item.popular ? 'featured' : ''}}" bindtap="subscribe" data-plan="{{item.id}}">
        {{item.cta}}
      </button>
    </view>
  </view>

  <!-- 常见问题 - 折叠面板 -->
  <view class="faq-section-premium">
    <text class="section-title-premium">常见问题</text>
    <view class="faq-list-premium">
      <view wx:for="{{faqs}}" wx:key="question" class="faq-item-premium" bindtap="toggleFaq" data-index="{{index}}">
        <view class="faq-question-premium">
          <text class="faq-text-premium">{{item.question}}</text>
          <text class="faq-arrow {{item.open ? 'open' : ''}}">›</text>
        </view>
        <view wx:if="{{item.open}}" class="faq-answer-premium">
          <text class="faq-answer-text">{{item.answer}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 支付弹窗 -->
  <view wx:if="{{showPayment}}" class="modal-overlay" catchtap="closePayment">
    <view class="modal-premium" catchtap="stop">
      <!-- 弹窗头部 -->
      <view class="modal-header-premium">
        <text class="modal-title-premium">确认订阅</text>
        <view class="modal-close-premium" bindtap="closePayment">
          <text class="close-icon-premium">✕</text>
        </view>
      </view>

      <!-- 计划信息 -->
      <view class="modal-plan-premium">
        <view class="modal-plan-row">
          <text class="modal-plan-name">{{selectedPlan.name}}</text>
          <text class="modal-plan-price">¥{{selectedPlan.price}}</text>
        </view>
        <text class="modal-plan-period">周期：{{selectedPlan.period}}</text>
      </view>

      <!-- 支付方式 -->
      <view class="payment-options-premium">
        <text class="options-title-premium">选择支付方式</text>
        <view class="payment-grid-premium">
          <view wx:for="{{paymentMethods}}" wx:key="id"
                class="payment-option-premium {{paymentMethod === item.id ? 'selected' : ''}}"
                bindtap="selectPaymentMethod"
                data-id="{{item.id}}">
            <text class="payment-option-icon">{{item.icon}}</text>
            <text class="payment-option-name">{{item.name}}</text>
          </view>
        </view>
      </view>

      <!-- 支付按钮 -->
      <view class="modal-actions-premium">
        <button class="modal-btn-secondary" bindtap="closePayment">取消</button>
        <button class="modal-btn-primary" bindtap="confirmPayment" disabled="{{paying}}">
          {{paying ? '处理中...' : '确认支付'}}
        </button>
      </view>

      <!-- 安全提示 -->
      <view class="security-tips-premium">
        <view class="security-tip">
          <text class="security-icon">🔒</text>
          <text class="security-text">SSL 加密支付</text>
        </view>
        <view class="security-tip">
          <text class="security-icon">✓</text>
          <text class="security-text">7 天无理由退款</text>
        </view>
      </view>
    </view>
  </view>
</view>
