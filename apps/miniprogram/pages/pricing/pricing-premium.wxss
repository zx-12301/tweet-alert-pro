/*
 * 🎨 定价页面 - 高级设计样式
 *
 * 设计原则：
 * - 去除廉价渐变，使用纯净背景 + 精致边框
 * - 统一圆角系统，使用 12px/16px/20px
 * - 颜色系统使用莫兰迪色系
 * - 间距使用 24px/32px/48px 标准体系
 * - 弱化装饰元素，强化信息层级
 */

/* ====================
   页面容器 - Page Container
   ==================== */
.premium-container {
  background: #fafafa;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ====================
   极简头部 - Minimal Header
   ==================== */
.premium-header {
  padding: 48rpx 32rpx 32rpx;
  background: #ffffff;
}

.header-content {
  margin-bottom: 32rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  letter-spacing: -0.5rpx;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: #6b7280;
  font-weight: 400;
}

/* 信任标签 */
.trust-badges {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.trust-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: #f8fafc;
  border-radius: 8rpx;
  border: 1px solid #e5e7eb;
}

.trust-icon {
  font-size: 22rpx;
  font-weight: 700;
  color: #059669;
}

.trust-text {
  font-size: 24rpx;
  color: #475569;
  font-weight: 500;
}

/* ====================
   计划区域 - Plans Section
   ==================== */
.plans-section {
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 计划卡片 */
.plan-card-premium {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  border: 2px solid #e5e7eb;
  transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}

.plan-card-premium.featured {
  border-color: #334155;
  box-shadow: 0 4px 16px rgba(51, 65, 85, 0.1);
}

.plan-card-premium:active {
  transform: translateY(-2rpx);
}

/* 热门标签 */
.popular-tag {
  position: absolute;
  top: -12rpx;
  right: 32rpx;
  padding: 6rpx 16rpx;
  background: #334155;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
}

.popular-tag-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 计划头部 */
.plan-header-premium {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.plan-name-premium {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.plan-tag-premium {
  font-size: 22rpx;
  font-weight: 500;
  color: #6b7280;
  background: #f3f4f6;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

/* 价格 */
.plan-price-premium {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-bottom: 32rpx;
}

.price-symbol {
  font-size: 28rpx;
  font-weight: 600;
  color: #6b7280;
}

.price-value-premium {
  font-size: 56rpx;
  font-weight: 800;
  color: #111827;
  line-height: 1;
  letter-spacing: -1rpx;
}

.price-period {
  font-size: 24rpx;
  color: #9ca3af;
  font-weight: 500;
}

/* 功能列表 */
.plan-features-premium {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.feature-row-premium {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.feature-check {
  font-size: 24rpx;
  font-weight: 700;
  color: #059669;
  line-height: 1.6;
  flex-shrink: 0;
}

.feature-text-premium {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
}

/* 计划按钮 */
.plan-btn-premium {
  width: 100%;
  padding: 28rpx;
  background: #f3f4f6;
  color: #374151;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
}

.plan-btn-premium.featured {
  background: #334155;
  color: #ffffff;
  box-shadow: 0 2px 8px rgba(51, 65, 85, 0.2);
}

.plan-btn-premium:active {
  transform: translateY(-1rpx);
}

.plan-btn-premium.featured:active {
  box-shadow: 0 4px 12px rgba(51, 65, 85, 0.3);
}

/* ====================
   常见问题 - FAQ Section
   ==================== */
.faq-section-premium {
  padding: 32rpx 24rpx;
}

.section-title-premium {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 24rpx;
}

.faq-list-premium {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.faq-item-premium {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1px solid #e5e7eb;
  transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
}

.faq-item-premium:active {
  background: #fafafa;
}

.faq-question-premium {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
}

.faq-text-premium {
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
  flex: 1;
  padding-right: 16rpx;
}

.faq-arrow {
  font-size: 32rpx;
  color: #9ca3af;
  transition: transform 200ms cubic-bezier(0.4, 0, 0.2, 1);
  font-weight: 300;
}

.faq-arrow.open {
  transform: rotate(90deg);
}

.faq-answer-premium {
  padding: 0 24rpx 24rpx;
}

.faq-answer-text {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
}

/* ====================
   支付弹窗 - Payment Modal
   ==================== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.modal-premium {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  max-height: 85vh;
  overflow-y: auto;
  animation: slideUp 300ms cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

/* 弹窗头部 */
.modal-header-premium {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.modal-title-premium {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.modal-close-premium {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #f3f4f6;
  transition: background 200ms ease;
}

.modal-close-premium:active {
  background: #e5e7eb;
}

.close-icon-premium {
  font-size: 28rpx;
  color: #6b7280;
}

/* 计划信息 */
.modal-plan-premium {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.modal-plan-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.modal-plan-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.modal-plan-price {
  font-size: 36rpx;
  font-weight: 800;
  color: #111827;
}

.modal-plan-period {
  font-size: 24rpx;
  color: #6b7280;
}

/* 支付方式 */
.payment-options-premium {
  margin-bottom: 32rpx;
}

.options-title-premium {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 16rpx;
}

.payment-grid-premium {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.payment-option-premium {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  border: 2px solid transparent;
  transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
}

.payment-option-premium.selected {
  border-color: #334155;
  background: #f1f5f9;
}

.payment-option-icon {
  font-size: 40rpx;
}

.payment-option-name {
  font-size: 24rpx;
  color: #475569;
  font-weight: 500;
}

/* 弹窗操作 */
.modal-actions-premium {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.modal-btn-secondary {
  flex: 1;
  padding: 28rpx;
  background: #f3f4f6;
  color: #374151;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  transition: all 200ms ease;
}

.modal-btn-secondary:active {
  background: #e5e7eb;
}

.modal-btn-primary {
  flex: 2;
  padding: 28rpx;
  background: #334155;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 2px 8px rgba(51, 65, 85, 0.2);
  transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
}

.modal-btn-primary:active {
  transform: translateY(-1rpx);
  box-shadow: 0 4px 12px rgba(51, 65, 85, 0.3);
}

/* 安全提示 */
.security-tips-premium {
  display: flex;
  gap: 24rpx;
  justify-content: center;
  padding-top: 24rpx;
  border-top: 1px solid #e5e7eb;
}

.security-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.security-icon {
  font-size: 24rpx;
}

.security-text {
  font-size: 22rpx;
  color: #6b7280;
  font-weight: 500;
}

/* ====================
   页面进入动画 - Page Entry
   ==================== */
.page-enter {
  animation: pageEnter 400ms cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes pageEnter {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
