<view class="page-container">
  <!-- 页面头部 -->
  <view class="page-header card-gradient-blue">
    <text class="page-title">功能配置</text>
    <text class="page-subtitle">配置第三方服务和通知渠道</text>
  </view>

  <!-- 配置说明 -->
  <view class="config-notice card">
    <view class="notice-content">
      <text class="notice-icon">💡</text>
      <view class="notice-text-wrapper">
        <text class="notice-title">配置指南</text>
        <text class="notice-desc">详细配置步骤请查看配置清单文档或访问 GitHub 仓库</text>
      </view>
    </view>
  </view>

  <!-- 选项卡 -->
  <view class="tabs-container">
    <scroll-view class="tabs-scroll" scroll-x="{{true}}" enable-flex="{{true}}">
      <view class="tabs-wrapper">
        <view wx:for="{{tabs}}" wx:key="id" 
              class="tab-item {{activeTab === item.id ? 'active' : ''}}" 
              bindtap="switchTab" 
              data-id="{{item.id}}">
          <text class="tab-icon">{{item.icon}}</text>
          <text class="tab-name">{{item.name}}</text>
          <view wx:if="{{item.required}}" class="tab-badge"></view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- Twitter API 配置 -->
  <view wx:if="{{activeTab === 'twitter'}}" class="tab-content animate-fade-in">
    <view class="config-header card-gradient-twitter">
      <text class="config-title">🐦 Twitter API 配置</text>
      <text class="config-desc">在 Twitter Developer Portal 申请 API 密钥</text>
      <view class="config-badge required">必须配置</view>
    </view>
    
    <view class="config-form card">
      <view class="form-row">
        <view class="form-item half">
          <view class="form-label">
            <text>API Key</text>
            <text class="required">*</text>
          </view>
          <input class="form-input" type="text" value="{{settings.twitterApiKey}}" bindinput="onInput" data-field="twitterApiKey" placeholder="请输入 API Key" />
        </view>
        
        <view class="form-item half">
          <view class="form-label">
            <text>API Secret</text>
            <text class="required">*</text>
          </view>
          <input class="form-input" type="password" value="{{settings.twitterApiSecret}}" bindinput="onInput" data-field="twitterApiSecret" placeholder="请输入 API Secret" />
        </view>
      </view>
      
      <view class="divider"></view>
      
      <view class="form-row">
        <view class="form-item half">
          <view class="form-label">
            <text>Access Token</text>
            <text class="required">*</text>
          </view>
          <input class="form-input" type="password" value="{{settings.twitterAccessToken}}" bindinput="onInput" data-field="twitterAccessToken" placeholder="请输入 Access Token" />
        </view>
        
        <view class="form-item half">
          <view class="form-label">
            <text>Access Token Secret</text>
            <text class="required">*</text>
          </view>
          <input class="form-input" type="password" value="{{settings.twitterAccessSecret}}" bindinput="onInput" data-field="twitterAccessSecret" placeholder="请输入 Access Token Secret" />
        </view>
      </view>
      
      <view class="form-actions">
        <button class="action-btn btn-test" bindtap="testConnection" data-type="twitter">
          {{testing.twitter ? '测试中...' : '🔍 测试连接'}}
        </button>
      </view>
      
      <view wx:if="{{testResults.twitter}}" class="test-result {{testResults.twitter.success ? 'success' : 'error'}}">
        <text class="result-icon">{{testResults.twitter.success ? '✅' : '❌'}}</text>
        <text class="result-text">{{testResults.twitter.message}}</text>
      </view>
      
      <view class="config-tip">
        <text class="tip-icon">⚠️</text>
        <text class="tip-text">注意：需要申请 Twitter API v2 的读取权限才能监控用户推文</text>
      </view>
    </view>
  </view>

  <!-- Twilio 配置 -->
  <view wx:if="{{activeTab === 'twilio'}}" class="tab-content animate-fade-in">
    <view class="config-header card-gradient-twilio">
      <text class="config-title">📞 Twilio 语音电话配置</text>
      <text class="config-desc">在 Twilio Console 获取账户信息</text>
      <view class="config-badge required">必须配置</view>
    </view>
    
    <view class="config-form card">
      <view class="form-item">
        <view class="form-label">
          <text>Account SID</text>
          <text class="required">*</text>
        </view>
        <input class="form-input" type="text" value="{{settings.twilioAccountSid}}" bindinput="onInput" data-field="twilioAccountSid" placeholder="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" />
      </view>
      
      <view class="divider"></view>
      
      <view class="form-item">
        <view class="form-label">
          <text>Auth Token</text>
          <text class="required">*</text>
        </view>
        <input class="form-input" type="password" value="{{settings.twilioAuthToken}}" bindinput="onInput" data-field="twilioAuthToken" placeholder="请输入 Auth Token" />
      </view>
      
      <view class="divider"></view>
      
      <view class="form-item">
        <view class="form-label">
          <text>电话号码</text>
          <text class="optional">可选</text>
        </view>
        <input class="form-input" type="tel" value="{{settings.twilioPhoneNumber}}" bindinput="onInput" data-field="twilioPhoneNumber" placeholder="+1234567890" />
        <text class="form-tip">用于外呼的 Twilio 号码</text>
      </view>
      
      <view class="form-actions">
        <button class="action-btn btn-test" bindtap="testConnection" data-type="twilio">
          {{testing.twilio ? '测试中...' : '📞 测试电话'}}
        </button>
      </view>
      
      <view wx:if="{{testResults.twilio}}" class="test-result {{testResults.twilio.success ? 'success' : 'error'}}">
        <text class="result-icon">{{testResults.twilio.success ? '✅' : '❌'}}</text>
        <text class="result-text">{{testResults.twilio.message}}</text>
      </view>
      
      <view class="config-tip tip-green">
        <text class="tip-icon">💡</text>
        <text class="tip-text">提示：Twilio 新账户默认有$15 试用额度，可以发送测试短信和拨打验证过的号码</text>
      </view>
    </view>
  </view>

  <!-- 邮件服务配置 -->
  <view wx:if="{{activeTab === 'email'}}" class="tab-content animate-fade-in">
    <view class="config-header card-gradient-email">
      <text class="config-title">📧 SMTP 邮件服务配置</text>
      <text class="config-desc">推荐使用 SendGrid 或阿里云邮件推送</text>
      <view class="config-badge required">必须配置</view>
    </view>
    
    <view class="config-form card">
      <view class="form-row">
        <view class="form-item half">
          <view class="form-label">
            <text>SMTP 服务器</text>
          </view>
          <input class="form-input" type="text" value="{{settings.smtpHost}}" bindinput="onInput" data-field="smtpHost" placeholder="smtp.example.com" />
        </view>
        
        <view class="form-item half">
          <view class="form-label">
            <text>端口</text>
          </view>
          <picker class="form-picker" mode="selector" range="{{smtpPorts}}" value="{{smtpPortIndex}}" bindchange="onSmtpPortChange">
            <view class="form-input form-picker-value">{{smtpPorts[smtpPortIndex]}}</view>
          </picker>
        </view>
      </view>
      
      <view class="divider"></view>
      
      <view class="form-item">
        <view class="form-label">
          <text>用户名</text>
        </view>
        <input class="form-input" type="text" value="{{settings.smtpUser}}" bindinput="onInput" data-field="smtpUser" placeholder="username@example.com" />
      </view>
      
      <view class="divider"></view>
      
      <view class="form-item">
        <view class="form-label">
          <text>密码 / 授权码</text>
        </view>
        <input class="form-input" type="password" value="{{settings.smtpPassword}}" bindinput="onInput" data-field="smtpPassword" placeholder="请输入密码或授权码" />
      </view>
      
      <view class="divider"></view>
      
      <view class="form-item">
        <view class="form-label">
          <text>发件人邮箱</text>
        </view>
        <input class="form-input" type="email" value="{{settings.smtpFrom}}" bindinput="onInput" data-field="smtpFrom" placeholder="noreply@example.com" />
      </view>
      
      <view class="form-actions">
        <button class="action-btn btn-test" bindtap="testConnection" data-type="email">
          {{testing.email ? '测试中...' : '📧 测试邮件'}}
        </button>
      </view>
      
      <view wx:if="{{testResults.email}}" class="test-result {{testResults.email.success ? 'success' : 'error'}}">
        <text class="result-icon">{{testResults.email.success ? '✅' : '❌'}}</text>
        <text class="result-text">{{testResults.email.message}}</text>
      </view>
      
      <view class="config-tip">
        <text class="tip-title">常用邮箱 SMTP 配置</text>
        <view class="tip-list">
          <text class="tip-item">• Gmail: smtp.gmail.com:587</text>
          <text class="tip-item">• 163 邮箱：smtp.163.com:587</text>
          <text class="tip-item">• QQ 邮箱：smtp.qq.com:587</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Webhook 配置 -->
  <view wx:if="{{activeTab === 'webhook'}}" class="tab-content animate-fade-in">
    <view class="config-header card-gradient-webhook">
      <text class="config-title">💬 消息通知配置</text>
      <text class="config-desc">配置默认的 Webhook 地址，用于发送通知到飞书、钉钉、企业微信等平台</text>
      <view class="config-badge optional">可选配置</view>
    </view>
    
    <view class="config-form card">
      <view class="form-item">
        <view class="form-label">
          <text>默认 Webhook URL</text>
        </view>
        <input class="form-input" type="url" value="{{settings.defaultWebhook}}" bindinput="onInput" data-field="defaultWebhook" placeholder="https://open.feishu.cn/open-apis/bot/v2/hook/xxx" />
        <text class="form-tip">此地址将作为创建任务时的默认 Webhook 选项</text>
      </view>
      
      <view class="form-actions">
        <button class="action-btn btn-test" bindtap="testConnection" data-type="webhook">
          {{testing.webhook ? '测试中...' : '💬 测试 Webhook'}}
        </button>
      </view>
      
      <view wx:if="{{testResults.webhook}}" class="test-result {{testResults.webhook.success ? 'success' : 'error'}}">
        <text class="result-icon">{{testResults.webhook.success ? '✅' : '❌'}}</text>
        <text class="result-text">{{testResults.webhook.message}}</text>
      </view>
      
      <!-- Webhook 格式示例 -->
      <view class="webhook-examples">
        <view class="example-title">常用 Webhook 格式</view>
        
        <view class="example-card example-feishu">
          <view class="example-header">
            <text class="example-icon">🚀</text>
            <text class="example-name">飞书机器人</text>
          </view>
          <text class="example-url">https://open.feishu.cn/open-apis/bot/v2/hook/TOKEN</text>
        </view>
        
        <view class="example-card example-dingtalk">
          <view class="example-header">
            <text class="example-icon">📌</text>
            <text class="example-name">钉钉机器人</text>
          </view>
          <text class="example-url">https://oapi.dingtalk.com/robot/send?access_token=TOKEN</text>
        </view>
        
        <view class="example-card example-wechat">
          <view class="example-header">
            <text class="example-icon">💼</text>
            <text class="example-name">企业微信机器人</text>
          </view>
          <text class="example-url">https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=KEY</text>
        </view>
      </view>
      
      <view class="config-tip">
        <text class="tip-title">💡 如何获取 Webhook</text>
        <view class="tip-list">
          <text class="tip-item">• 飞书：群聊 → ... → 添加机器人 → 自定义机器人</text>
          <text class="tip-item">• 钉钉：群聊 → ... → 智能群助手 → 添加机器人 → 自定义</text>
          <text class="tip-item">• 企业微信：群聊 → ... → 添加群机器人 → 新建</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="save-section safe-area-bottom">
    <button class="save-btn btn-primary" bindtap="saveSettings" disabled="{{saving}}">
      {{saving ? '保存中...' : '保存配置'}}
    </button>
  </view>
</view>
