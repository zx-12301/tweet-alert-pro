.container {
  padding: 20rpx;
}

.section {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #374151;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  padding: 20rpx;
  background-color: #f9fafb;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: 1rpx solid #e5e7eb;
}

.about-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.about-item:last-child {
  border-bottom: none;
}

.about-label {
  font-size: 28rpx;
  color: #6b7280;
}

.about-value {
  font-size: 28rpx;
  color: #2563eb;
}

.save-btn {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: #ffffff;
  margin-top: 40rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}
