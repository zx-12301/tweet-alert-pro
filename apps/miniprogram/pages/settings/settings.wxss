/* ==========================================================================
   功能配置页 - Figma 设计 100% 还原
   深色主题
   ========================================================================== */

page {
  background: #0B1120;
  min-height: 100vh;
}

.dark-page {
  min-height: 100vh;
  background: #0B1120;
  position: relative;
  overflow: hidden;
  height: 100vh;
}

/* 背景装饰光晕 */
.bg-glow {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 120%;
  height: 30%;
  background: radial-gradient(ellipse at top, rgba(37, 99, 235, 0.1) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

/* ==========================================================================
   头部（固定）
   ========================================================================== */

.header-sticky {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: rgba(11, 17, 32, 0.8);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  padding-top: calc(88rpx + env(safe-area-inset-top));
  padding-bottom: 24rpx;
  padding-left: 40rpx;
  padding-right: 40rpx;
  z-index: 100;
}

.header-content {
  display: flex;
  align-items: center;
}

.header-info {
  flex: 1;
}

.header-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.3;
  margin-bottom: 4rpx;
}

.header-subtitle {
  display: block;
  font-size: 18rpx;
  color: #94a3b8;
}



/* ==========================================================================
   全局提示框
   ========================================================================== */

.guide-alert {
  padding: 0 40rpx;
}

.alert-content {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 28rpx;
  background: rgba(245, 158, 11, 0.1);
  border: 1rpx solid rgba(245, 158, 11, 0.2);
  border-radius: 32rpx;
}

.alert-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.alert-text-wrapper {
  flex: 1;
}

.alert-title {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(251, 191, 36, 0.9);
  margin-bottom: 8rpx;
}

.alert-desc {
  display: block;
  font-size: 18rpx;
  color: rgba(251, 191, 36, 0.7);
  line-height: 1.5;
}

.alert-link {
  color: rgba(251, 191, 36, 0.9);
  text-decoration: underline;
  font-weight: 500;
}

/* ==========================================================================
   Tab 导航
   ========================================================================== */

.tab-navigation {
  padding: 0 40rpx;
  margin-top: 40rpx;
}

.tab-navigation {
  display: flex;
  background: #121A2F;
  padding: 8rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  gap: 8rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 16rpx;
  border-radius: 20rpx;
  position: relative;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #ffffff;
}

.tab-icon-wrapper {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  transition: all 0.3s ease;
}

.tab-item.active .tab-icon-wrapper {
  color: #ffffff;
}

.tab-item[data-tab="twitter"].active .tab-icon-wrapper { color: #1DA1F2; }
.tab-item[data-tab="twilio"].active .tab-icon-wrapper { color: #f43f5e; }
.tab-item[data-tab="email"].active .tab-icon-wrapper { color: #818cf8; }
.tab-item[data-tab="webhook"].active .tab-icon-wrapper { color: #10b981; }

.tab-label {
  font-size: 18rpx;
  font-weight: 500;
  color: #64748b;
}

.tab-item.active .tab-label {
  color: #ffffff;
}

.required-dot {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  width: 12rpx;
  height: 12rpx;
  background: #f43f5e;
  border-radius: 50%;
  border: 2rpx solid #121A2F;
}

/* ==========================================================================
   配置面板
   ========================================================================== */

.config-panel {
  padding: 0 40rpx 40rpx;
  margin-top: 24rpx;
  width: 100%;
  box-sizing: border-box;
  overflow-x: hidden;
}

.animate-show {
  animation: fadeInSlide 0.3s ease;
}

@keyframes fadeInSlide {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 配置头部 */
.config-header {
  padding: 40rpx;
  border-radius: 32rpx 32rpx 0 0;
  position: relative;
  overflow: hidden;
}

.header-twitter {
  background: linear-gradient(135deg, rgba(29, 161, 242, 0.2) 0%, rgba(29, 161, 242, 0.05) 100%);
  border: 1rpx solid rgba(29, 161, 242, 0.3);
}

.header-twilio {
  background: linear-gradient(135deg, rgba(244, 63, 94, 0.2) 0%, rgba(244, 63, 94, 0.05) 100%);
  border: 1rpx solid rgba(244, 63, 94, 0.3);
}

.header-email {
  background: linear-gradient(135deg, rgba(129, 140, 248, 0.2) 0%, rgba(129, 140, 248, 0.05) 100%);
  border: 1rpx solid rgba(129, 140, 248, 0.3);
}

.header-webhook {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.2) 0%, rgba(245, 158, 11, 0.05) 100%);
  border: 1rpx solid rgba(245, 158, 11, 0.3);
}

.header-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 20rpx;
}

.icon-twitter {
  background: rgba(29, 161, 242, 0.2);
  color: #1DA1F2;
}

.icon-twilio {
  background: rgba(244, 63, 94, 0.2);
  color: #f43f5e;
}

.icon-email {
  background: rgba(129, 140, 248, 0.2);
  color: #818cf8;
}

.icon-webhook {
  background: rgba(245, 158, 11, 0.2);
  color: #f59e0b;
}

.config-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.config-desc {
  display: block;
  font-size: 18rpx;
  color: #cbd5e1;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.config-badges {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.badge {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 16rpx;
  font-weight: 600;
}

.badge-required {
  background: rgba(244, 63, 94, 0.2);
  color: #f43f5e;
  border: 1rpx solid rgba(244, 63, 94, 0.2);
}

.badge-optional {
  background: rgba(100, 116, 139, 0.2);
  color: #94a3b8;
  border: 1rpx solid rgba(100, 116, 139, 0.2);
}

.badge-desc {
  font-size: 18rpx;
  color: #64748b;
}

/* 配置表单 */
.config-form {
  background: #121A2F;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  border-top: none;
  border-radius: 0 0 32rpx 32rpx;
  padding: 40rpx;
}

.form-input-group {
  margin-bottom: 32rpx;
}

.form-input-group:last-child {
  margin-bottom: 0;
}

.input-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.input-label text {
  font-size: 22rpx;
  font-weight: 600;
  color: #cbd5e1;
}

.required {
  color: #fb7185 !important;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 28rpx;
  background: #0B1120;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #ffffff;
  font-family: monospace;
  line-height: 80rpx;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: rgba(59, 130, 246, 0.5);
  background: #0f1623;
}

.form-input::placeholder {
  color: #475569;
  font-size: 26rpx;
  line-height: 80rpx;
}

.input-helper {
  display: block;
  font-size: 18rpx;
  color: #64748b;
  margin-top: 12rpx;
  padding-left: 4rpx;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.form-input-group.half {
  flex: 1;
}

.form-picker {
  width: 100%;
  height: 80rpx;
}

.form-picker-value {
  width: 100%;
  height: 80rpx;
  padding: 0 28rpx;
  background: #0B1120;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #ffffff;
  font-family: monospace;
  line-height: 80rpx;
  box-sizing: border-box;
}

.form-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 24rpx;
}

.test-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  background: #10b981;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #ffffff;
  transition: all 0.2s ease;
  white-space: nowrap;
}

.test-btn:active {
  transform: scale(0.95);
  background: #059669;
}

.test-btn-icon {
  font-size: 18rpx;
}

/* 警告框 */
.warning-box {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 28rpx;
  margin-top: 32rpx;
  background: rgba(245, 158, 11, 0.1);
  border: 1rpx solid rgba(245, 158, 11, 0.2);
  border-radius: 24rpx;
}

.warning-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.warning-text {
  font-size: 20rpx;
  color: rgba(251, 191, 36, 0.8);
  line-height: 1.5;
}

/* 提示框 */
.tip-box {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 28rpx;
  margin-top: 32rpx;
  background: rgba(16, 185, 129, 0.1);
  border: 1rpx solid rgba(16, 185, 129, 0.2);
  border-radius: 24rpx;
}

.tip-box.tip-amber {
  background: rgba(245, 158, 11, 0.1);
  border: 1rpx solid rgba(245, 158, 11, 0.2);
}

.tip-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tip-icon {
  font-size: 32rpx;
}

.tip-title {
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(251, 191, 36, 0.9);
}

.tip-text {
  font-size: 20rpx;
  color: rgba(16, 185, 129, 0.8);
  line-height: 1.5;
}

.tip-box.tip-amber .tip-text {
  color: rgba(251, 191, 36, 0.8);
}

.tip-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-item {
  font-size: 18rpx;
  color: rgba(251, 191, 36, 0.7);
  line-height: 1.5;
  font-family: monospace;
}

/* Webhook 区域 */
.webhook-section {
  margin-top: 40rpx;
  margin-bottom: 32rpx;
}

.section-divider-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.divider-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #ffffff;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.05);
}

.webhook-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.webhook-card {
  padding: 24rpx;
  background: #121A2F;
  border-radius: 20rpx;
  border-left: 4rpx solid;
}

.card-blue {
  border-left-color: #3b82f6;
}

.card-blue-light {
  border-left-color: #60a5fa;
}

.card-green {
  border-left-color: #10b981;
}

.webhook-card-title {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  color: #e2e8f0;
  margin-bottom: 16rpx;
}

.webhook-url-box {
  width: 100%;
  padding: 16rpx 20rpx;
  background: #0B1120;
  border-radius: 12rpx;
  overflow-x: auto;
  box-sizing: border-box;
}

.webhook-url {
  display: block;
  font-size: 16rpx;
  color: #64748b;
  font-family: monospace;
  white-space: nowrap;
  overflow-x: auto;
}

/* 底部占位 */
.bottom-spacer-large {
  height: calc(200rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}

/* ==========================================================================
   底部保存按钮
   ========================================================================== */

.bottom-save-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, #0B1120 0%, rgba(11, 17, 32, 0.9) 100%);
  z-index: 100;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(to right, #2563eb, #3b82f6);
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  text-align: center;
  line-height: 88rpx;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.3);
  transition: all 0.2s ease;
}

.save-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.2);
}
