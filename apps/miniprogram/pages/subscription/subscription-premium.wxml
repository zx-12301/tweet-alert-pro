<view class="page-container animate-fade-in">
  <!-- 订阅卡片 - 极简设计 -->
  <view class="subscription-card-premium">
    <view class="subscription-header-premium">
      <view>
        <text class="subscription-label-premium">当前计划</text>
        <text class="subscription-name-premium">{{subscription.plan === 'pro' ? '专业版' : subscription.plan === 'enterprise' ? '企业版' : '免费版'}}</text>
      </view>
      <view class="subscription-status-premium {{subscription.status === 'active' ? 'active' : 'inactive'}}">
        <view class="status-dot-premium"></view>
        <text class="status-text-premium">{{subscription.status === 'active' ? '活跃' : '已取消'}}</text>
      </view>
    </view>
    
    <view class="subscription-price-premium">
      <text class="price-symbol-premium">¥</text>
      <text class="price-value-premium">{{subscription.plan === 'pro' ? '29' : subscription.plan === 'enterprise' ? '99' : '0'}}</text>
      <text class="price-period-premium">/月</text>
    </view>
    
    <view class="subscription-features-premium">
      <view class="feature-item-premium">
        <text class="feature-icon-premium">✓</text>
        <text class="feature-text-premium">{{subscription.dailyNotificationLimit || 5}} 次通知/天</text>
      </view>
      <view class="feature-item-premium">
        <text class="feature-icon-premium">✓</text>
        <text class="feature-text-premium">{{subscription.maxTasks || 3}} 个监控任务</text>
      </view>
    </view>
  </view>

  <!-- 用量统计 - 环形进度条 -->
  <view class="section">
    <text class="premium-h2 section-title">用量统计</text>
    
    <view class="usage-card-premium">
      <view class="usage-header-premium">
        <text class="usage-label-premium">通知额度</text>
        <text class="usage-value-premium">{{usedNotifications}} / {{subscription.dailyNotificationLimit || 5}}</text>
      </view>
      
      <view class="usage-progress-premium">
        <view class="usage-bar-premium">
          <view class="usage-fill-premium" style="width: {{usagePercent}}%"></view>
        </view>
        <text class="usage-percent-premium">{{usagePercent}}%</text>
      </view>
      
      <view wx:if="{{usagePercent < 50}}" class="usage-tip-premium tip-success">
        <text class="tip-icon-premium">✅</text>
        <text class="tip-text-premium">用量健康，可正常使用</text>
      </view>
      
      <view wx:elif="{{usagePercent < 80}}" class="usage-tip-premium tip-warning">
        <text class="tip-icon-premium">⚠️</text>
        <text class="tip-text-premium">用量即将耗尽，请注意</text>
      </view>
      
      <view wx:else class="usage-tip-premium tip-danger">
        <text class="tip-icon-premium">🔴</text>
        <text class="tip-text-premium">用量已耗尽，请升级计划</text>
      </view>
    </view>
  </view>

  <!-- 订阅详情 - 列表 -->
  <view class="section">
    <text class="premium-h2 section-title">订阅详情</text>
    
    <view class="detail-list-premium">
      <view class="detail-row-premium">
        <text class="detail-label-premium">订阅周期</text>
        <text class="detail-value-premium">按月订阅</text>
      </view>
      
      <view class="premium-divider"></view>
      
      <view class="detail-row-premium">
        <text class="detail-label-premium">下次账单日</text>
        <text class="detail-value-premium">2026-04-07</text>
      </view>
      
      <view class="premium-divider"></view>
      
      <view class="detail-row-premium">
        <text class="detail-label-premium">自动续费</text>
        <view class="switch-premium {{autoRenew ? 'on' : 'off'}}">
          <view class="switch-dot-premium"></view>
        </view>
      </view>
      
      <view class="premium-divider"></view>
      
      <view class="detail-row-premium">
        <text class="detail-label-premium">支付方式</text>
        <text class="detail-value-premium">支付宝</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section-premium">
    <button class="premium-btn premium-btn-primary" bindtap="upgradePlan">升级计划</button>
    <button class="premium-btn premium-btn-secondary" bindtap="cancelSubscription">取消订阅</button>
  </view>
  
  <!-- 底部安全区域 -->
  <view class="tabbar-safe-area"></view>
</view>
