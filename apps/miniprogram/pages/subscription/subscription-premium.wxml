<view class="premium-container page-enter">
  <!-- 订阅卡片 - 极简设计 -->
  <view class="subscription-card-premium">
    <view class="sub-header-premium">
      <view class="sub-info-left">
        <text class="sub-label">当前计划</text>
        <text class="sub-name-premium">{{subscription.plan === 'pro' ? '专业版' : subscription.plan === 'enterprise' ? '企业版' : '免费版'}}</text>
      </view>
      <view class="sub-status-premium {{subscription.status === 'active' ? 'active' : 'inactive'}}">
        <text class="status-dot-mini">●</text>
        <text class="status-text-mini">{{subscription.status === 'active' ? '活跃' : '已取消'}}</text>
      </view>
    </view>

    <view class="sub-price-premium">
      <text class="price-symbol">¥</text>
      <text class="price-value-large">{{subscription.plan === 'pro' ? '29' : subscription.plan === 'enterprise' ? '99' : '0'}}</text>
      <text class="price-period">/月</text>
    </view>

    <view class="sub-features-premium">
      <view class="sub-feature-row">
        <text class="sub-feature-icon">✓</text>
        <text class="sub-feature-text">{{subscription.dailyNotificationLimit || 5}} 次通知/天</text>
      </view>
      <view class="sub-feature-row">
        <text class="sub-feature-icon">✓</text>
        <text class="sub-feature-text">{{subscription.maxTasks || 3}} 个监控任务</text>
      </view>
    </view>
  </view>

  <!-- 用量统计 -->
  <view class="section">
    <view class="section-header-premium">
      <text class="section-title-premium">用量统计</text>
      <text class="section-subtitle-premium">今日剩余 {{subscription.dailyNotificationLimit - usedNotifications}} 次</text>
    </view>

    <view class="usage-card-premium">
      <view class="usage-header-premium">
        <text class="usage-label">通知额度</text>
        <text class="usage-value">{{usedNotifications}} / {{subscription.dailyNotificationLimit || 5}}</text>
      </view>

      <view class="usage-progress-premium">
        <view class="progress-bar-premium">
          <view class="progress-fill-premium" style="width: {{usagePercent}}%"></view>
        </view>
        <text class="progress-percent">{{usagePercent}}%</text>
      </view>

      <view class="usage-status-premium {{usagePercent < 50 ? 'good' : usagePercent < 80 ? 'warning' : 'urgent'}}">
        <text class="status-icon-premium">{{usagePercent < 50 ? '✓' : usagePercent < 80 ? '!' : '×'}}</text>
        <text class="status-text-premium">
          {{usagePercent < 50 ? '用量健康' : usagePercent < 80 ? '即将耗尽' : '已耗尽，请升级'}}
        </text>
      </view>
    </view>
  </view>

  <!-- 订阅详情 -->
  <view class="section">
    <view class="section-header-premium">
      <text class="section-title-premium">订阅详情</text>
    </view>

    <view class="detail-card-premium">
      <view class="detail-row-premium">
        <text class="detail-label-premium">订阅周期</text>
        <text class="detail-value-premium">按月订阅</text>
      </view>
      <view class="detail-divider-premium"></view>
      <view class="detail-row-premium">
        <text class="detail-label-premium">下次账单日</text>
        <text class="detail-value-premium">2026-04-07</text>
      </view>
      <view class="detail-divider-premium"></view>
      <view class="detail-row-premium">
        <text class="detail-label-premium">自动续费</text>
        <view class="toggle-switch-premium active">
          <text class="toggle-dot-premium"></text>
        </view>
      </view>
      <view class="detail-divider-premium"></view>
      <view class="detail-row-premium">
        <text class="detail-label-premium">支付方式</text>
        <text class="detail-value-premium">支付宝</text>
      </view>
    </view>
  </view>

  <!-- 底部操作按钮 -->
  <view class="bottom-actions">
    <button class="btn-upgrade" bindtap="upgradePlan">
      <text class="btn-icon-upgrade">↑</text>
      <text>升级计划</text>
    </button>
    <button class="btn-cancel" bindtap="cancelSubscription">
      <text class="btn-icon-cancel">✕</text>
      <text>取消订阅</text>
    </button>
  </view>
</view>
