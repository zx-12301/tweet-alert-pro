/* ==========================================================================
   订阅管理页 - Premium Design
   极简数据展示
   ========================================================================== */

.page-container {
  min-height: 100vh;
  background-color: var(--bg);
  padding-bottom: 40rpx;
}

/* ==========================================================================
   订阅卡片 - 极简渐变
   ========================================================================== */

.subscription-card-premium {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  padding: var(--space-2xl) var(--space-lg);
  margin: 0;
  box-shadow: var(--shadow-md);
}

.subscription-header-premium {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--space-xl);
}

.subscription-label-premium {
  display: block;
  font-size: var(--tiny-size);
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: var(--space-xs);
}

.subscription-name-premium {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -1rpx;
}

.subscription-status-premium {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-full);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.status-dot-premium {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--success);
  box-shadow: 0 0 0 4rpx rgba(52, 199, 89, 0.2);
}

.subscription-status-premium.inactive .status-dot-premium {
  background: var(--text-tertiary);
  box-shadow: none;
}

.status-text-premium {
  font-size: var(--tiny-size);
  font-weight: 500;
  color: #ffffff;
}

.subscription-price-premium {
  display: flex;
  align-items: baseline;
  margin-bottom: var(--space-xl);
}

.price-symbol-premium {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
  margin-right: 4rpx;
}

.price-value-premium {
  font-size: 64rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1;
  letter-spacing: -2rpx;
}

.price-period-premium {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-left: var(--space-sm);
}

.subscription-features-premium {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.feature-item-premium {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.feature-icon-premium {
  width: 28rpx;
  height: 28rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  color: #ffffff;
  font-weight: 700;
}

.feature-text-premium {
  font-size: var(--caption-size);
  color: rgba(255, 255, 255, 0.9);
}

/* ==========================================================================
   用量统计 - 极简进度条
   ========================================================================== */

.usage-card-premium {
  background: var(--surface);
  border-radius: var(--radius-xl);
  padding: var(--space-lg);
  box-shadow: var(--shadow-sm);
}

.usage-header-premium {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-md);
}

.usage-label-premium {
  font-size: var(--body-size);
  font-weight: 500;
  color: var(--text-secondary);
}

.usage-value-premium {
  font-size: var(--body-size);
  font-weight: 600;
  color: var(--text-primary);
}

.usage-progress-premium {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  margin-bottom: var(--space-lg);
}

.usage-bar-premium {
  flex: 1;
  height: 12rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.usage-fill-premium {
  height: 100%;
  background: linear-gradient(90deg, var(--accent) 0%, var(--accent-light) 100%);
  border-radius: var(--radius-full);
  transition: width 0.5s var(--ease-standard);
}

.usage-percent-premium {
  font-size: var(--caption-size);
  font-weight: 600;
  color: var(--accent);
  min-width: 80rpx;
  text-align: right;
}

/* 用量提示 */
.usage-tip-premium {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-md);
  border-radius: var(--radius-md);
  font-size: var(--caption-size);
}

.tip-icon-premium {
  font-size: 28rpx;
}

.tip-text-premium {
  flex: 1;
  font-weight: 500;
}

.tip-success {
  background: var(--success-bg);
  color: var(--success);
}

.tip-warning {
  background: var(--warning-bg);
  color: var(--warning);
}

.tip-danger {
  background: var(--danger-bg);
  color: var(--danger);
}

/* ==========================================================================
   详情列表 - 极简行
   ========================================================================== */

.detail-list-premium {
  background: var(--surface);
  border-radius: var(--radius-xl);
  padding: 0;
  box-shadow: var(--shadow-sm);
}

.detail-row-premium {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-lg);
}

.detail-label-premium {
  font-size: var(--body-size);
  color: var(--text-secondary);
}

.detail-value-premium {
  font-size: var(--body-size);
  font-weight: 500;
  color: var(--text-primary);
}

/* 开关 */
.switch-premium {
  width: 80rpx;
  height: 44rpx;
  background: var(--border);
  border-radius: var(--radius-full);
  position: relative;
  transition: background 0.3s var(--ease-standard);
}

.switch-premium.on {
  background: var(--primary);
}

.switch-dot-premium {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 36rpx;
  height: 36rpx;
  background: #ffffff;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  transition: transform 0.3s var(--ease-standard);
}

.switch-premium.on .switch-dot-premium {
  transform: translateX(36rpx);
}

/* ==========================================================================
   操作区域
   ========================================================================== */

.action-section-premium {
  padding: var(--space-xl) var(--space-lg);
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

/* ==========================================================================
   响应式优化
   ========================================================================== */

@media (min-width: 768px) {
  .subscription-card-premium {
    padding: var(--space-3xl) var(--space-2xl);
  }
  
  .subscription-name-premium {
    font-size: 48rpx;
  }
  
  .price-value-premium {
    font-size: 72rpx;
  }
}
