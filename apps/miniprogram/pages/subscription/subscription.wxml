<view class="dark-page">
  <!-- 背景装饰光晕 -->
  <view class="bg-glow"></view>

  <!-- 主滚动内容 -->
  <scroll-view class="main-scroll" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}" bounces="{{false}}">

    <!-- 头部区域 -->
    <view class="header-section">
      <h1 class="page-title">订阅管理</h1>
      <view class="header-badges">
        <view class="badge-item">
          <text class="badge-icon">✓</text>
          <text class="badge-text">7 天无理由退款</text>
        </view>
        <view class="badge-divider"></view>
        <view class="badge-item">
          <text class="badge-text">随时取消</text>
        </view>
      </view>
    </view>

    <!-- 当前计划卡片 -->
    <view class="plan-card-wrapper">
      <view class="plan-card">
        <!-- 右上角标签 -->
        <view class="plan-badge">
          <text class="plan-badge-icon">♛</text>
          <text class="plan-badge-text">专业版</text>
        </view>

        <view class="plan-label">当前计划</view>

        <view class="plan-price">
          <text class="price-symbol">¥</text>
          <text class="price-value">29</text>
          <text class="price-period">/月</text>
        </view>

        <view class="plan-features">
          <view class="feature-item">
            <view class="feature-icon">✓</view>
            <text class="feature-text">100 次通知/天</text>
          </view>
          <view class="feature-item">
            <view class="feature-icon">✓</view>
            <text class="feature-text">20 个监控任务</text>
          </view>
          <view class="feature-item">
            <view class="feature-icon">✓</view>
            <text class="feature-text">全部通知渠道 (含语音电话)</text>
          </view>
          <view class="feature-item">
            <view class="feature-icon">✓</view>
            <text class="feature-text">1 分钟检测间隔</text>
          </view>
        </view>

        <view class="plan-actions">
          <view class="view-features-btn">
            <text>查看全部权益</text>
            <text class="chevron-icon">›</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 用量统计 -->
    <view class="section">
      <view class="section-header">
        <view class="section-title-wrapper">
          <text class="section-icon">⚡</text>
          <text class="section-title">用量统计</text>
        </view>
        <view class="section-remaining">
          <text>今日剩余 88 次</text>
        </view>
      </view>

      <view class="usage-card">
        <view class="usage-header">
          <text class="usage-label">通知额度</text>
          <view class="usage-value-wrapper">
            <text class="usage-value-large">12</text>
            <text class="usage-total">/ 100</text>
          </view>
        </view>

        <!-- 进度条 -->
        <view class="progress-container">
          <view class="progress-track">
            <view class="progress-fill" style="width: 12%">
              <view class="progress-glow"></view>
            </view>
          </view>
        </view>
        <view class="progress-percent">12%</view>

        <!-- 状态提示 -->
        <view class="usage-status good">
          <view class="status-icon-wrapper">
            <text class="status-check">✓</text>
          </view>
          <text class="status-text">用量健康，额度充足</text>
        </view>
      </view>
    </view>

    <!-- 订阅详情 -->
    <view class="section">
      <view class="section-header">
        <view class="section-title-wrapper">
          <text class="section-icon card">💳</text>
          <text class="section-title">订阅详情</text>
        </view>
      </view>

      <view class="detail-card">
        <view class="detail-row">
          <text class="detail-label">订阅周期</text>
          <text class="detail-value">按月订阅</text>
        </view>
        <view class="detail-divider"></view>
        <view class="detail-row">
          <text class="detail-label">下次账单日</text>
          <text class="detail-value">2026-04-07</text>
        </view>
        <view class="detail-divider"></view>
        <view class="detail-row">
          <text class="detail-label">自动续费</text>
          <view class="toggle-switch {{autoRenew ? 'active' : ''}}" bindtap="toggleAutoRenew">
            <view class="toggle-dot"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部操作按钮 -->
    <view class="bottom-actions">
      <view class="action-btn primary" bindtap="upgradePlan">
        <text class="btn-icon">↑</text>
        <text class="btn-text">升级计划</text>
      </view>
      <view class="action-btn danger" bindtap="cancelSubscription">
        <text class="btn-icon">×</text>
        <text class="btn-text">取消订阅</text>
      </view>
    </view>

    <!-- 常见问题 -->
    <view class="help-section">
      <view class="help-link" bindtap="viewHelp">
        <text class="help-icon">?</text>
        <text class="help-text">遇到问题？查看常见问题</text>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-spacer"></view>
  </scroll-view>
</view>
