<view class="container">
  <view class="header card">
    <view class="plan-name">{{subscription.plan === 'pro' ? '专业版' : subscription.plan === 'enterprise' ? '企业版' : '免费版'}}</view>
    <view class="plan-status">{{subscription.status === 'active' ? '✅ 活跃' : '⏸️ 已取消'}}</view>
  </view>

  <view class="usage-section card">
    <view class="section-title">用量统计</view>
    <view class="usage-item">
      <view class="usage-label">通知额度</view>
      <view class="usage-bar">
        <view class="usage-progress" style="width: {{usagePercent}}%"></view>
      </view>
      <view class="usage-text">{{usedNotifications}} / {{subscription.dailyNotificationLimit || 5}}</view>
    </view>
  </view>

  <view class="info-section card">
    <view class="info-row">
      <text class="info-label">订阅周期</text>
      <text class="info-value">按月订阅</text>
    </view>
    <view class="info-row">
      <text class="info-label">下次账单日</text>
      <text class="info-value">2026-04-07</text>
    </view>
    <view class="info-row">
      <text class="info-label">自动续费</text>
      <text class="info-value">✅ 已开启</text>
    </view>
  </view>

  <button class="upgrade-btn" bindtap="upgradePlan">升级计划</button>
  <button class="cancel-btn" bindtap="cancelSubscription">取消订阅</button>
</view>
