.header {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #ffffff;
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.plan-name {
  font-size: 40rpx;
  font-weight: 600;
}

.plan-status {
  font-size: 26rpx;
  opacity: 0.9;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 24rpx;
}

.usage-item {
  margin-bottom: 20rpx;
}

.usage-label {
  font-size: 28rpx;
  color: #374151;
  margin-bottom: 12rpx;
}

.usage-bar {
  height: 16rpx;
  background-color: #e5e7eb;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.usage-progress {
  height: 100%;
  background: linear-gradient(90deg, #3b82f6, #2563eb);
  border-radius: 8rpx;
  transition: width 0.3s;
}

.usage-text {
  font-size: 24rpx;
  color: #6b7280;
}

.info-section {
  margin-top: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #6b7280;
}

.info-value {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 500;
}

.upgrade-btn {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: #ffffff;
  margin-top: 40rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.cancel-btn {
  background-color: #fee2e2;
  color: #dc2626;
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}
