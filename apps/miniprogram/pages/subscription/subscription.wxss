/* ==========================================================================
   订阅管理页 - Figma 设计 100% 还原
   深色主题 #0B1120
   ========================================================================== */

page {
  background: #0B1120;
  min-height: 100vh;
}

.dark-page {
  min-height: 100vh;
  background: #0B1120;
  position: relative;
  overflow: hidden;
}

/* 背景装饰光晕 */
.bg-glow {
  position: absolute;
  top: -10%;
  right: -10%;
  width: 150%;
  height: 40%;
  background: radial-gradient(ellipse at top right, rgba(37, 99, 235, 0.15) 0%, rgba(139, 92, 246, 0.1) 50%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

/* 主滚动区域 */
.main-scroll {
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  z-index: 10;
}

/* ==========================================================================
   头部区域
   ========================================================================== */

.header-section {
  padding: 56rpx 40rpx 24rpx;
}

.page-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -1rpx;
  margin-bottom: 8rpx;
}

.header-badges {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.badge-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.badge-icon {
  font-size: 24rpx;
  color: #34d399;
  font-weight: 700;
}

.badge-text {
  font-weight: 500;
}

.badge-divider {
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: #64748b;
}

/* ==========================================================================
   当前计划卡片
   ========================================================================== */

.plan-card-wrapper {
  padding: 0 40rpx 48rpx;
}

.plan-card {
  position: relative;
  background: linear-gradient(to bottom right, #1E293B, #121A2F);
  border: 2rpx solid rgba(59, 130, 246, 0.3);
  border-radius: 48rpx;
  padding: 48rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx -20rpx rgba(37, 99, 235, 0.3);
}

/* 右上角装饰光 */
.plan-card::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 200rpx;
  height: 200rpx;
  background: rgba(59, 130, 246, 0.1);
  border-radius: 50%;
  filter: blur(40rpx);
  pointer-events: none;
  transform: translate(30%, -30%);
}

/* 专业版标签 */
.plan-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  background: rgba(59, 130, 246, 0.2);
  border: 1rpx solid rgba(59, 130, 246, 0.3);
  border-radius: 32rpx;
  backdrop-filter: blur(8rpx);
}

.plan-badge-icon {
  font-size: 24rpx;
  color: #60a5fa;
}

.plan-badge-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #60a5fa;
  letter-spacing: 1rpx;
}

.plan-label {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.plan-price {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-bottom: 40rpx;
}

.price-symbol {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}

.price-value {
  font-size: 100rpx;
  font-weight: 900;
  color: #ffffff;
  line-height: 1;
  letter-spacing: -2rpx;
}

.price-period {
  font-size: 28rpx;
  color: #94a3b8;
  font-weight: 500;
}

/* 功能列表 */
.plan-features {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.feature-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(16, 185, 129, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.feature-icon {
  font-size: 28rpx;
  color: #34d399;
  font-weight: 700;
  line-height: 1;
}

.feature-text {
  font-size: 26rpx;
  color: #cbd5e1;
  font-weight: 500;
  line-height: 1.5;
}

/* 查看全部权益按钮 */
.plan-actions {
  margin-top: 48rpx;
}

.view-features-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 100%;
  padding: 24rpx;
  background: rgba(59, 130, 246, 0.1);
  border: 1rpx solid rgba(59, 130, 246, 0.3);
  border-radius: 24rpx;
  transition: all 0.2s ease;
}

.view-features-btn:active {
  transform: scale(0.98);
  background: rgba(59, 130, 246, 0.15);
}

.view-features-btn {
  font-size: 26rpx;
  font-weight: 700;
  color: #60a5fa;
}

.chevron-icon {
  font-size: 32rpx;
  color: #60a5fa;
  line-height: 1;
}

/* ==========================================================================
   区块
   ========================================================================== */

.section {
  padding: 0 40rpx 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-icon {
  font-size: 36rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.section-remaining {
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 500;
}

/* ==========================================================================
   用量卡片
   ========================================================================== */

.usage-card {
  background: #121A2F;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.3);
}

.usage-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 16rpx;
}

.usage-label {
  font-size: 30rpx;
  color: #cbd5e1;
  font-weight: 500;
}

.usage-value-wrapper {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.usage-value-large {
  font-size: 44rpx;
  font-weight: 900;
  color: #ffffff;
}

.usage-total {
  font-size: 26rpx;
  color: #64748b;
  font-weight: 500;
}

/* 进度条 */
.progress-container {
  margin-bottom: 16rpx;
}

.progress-track {
  width: 100%;
  height: 20rpx;
  background: #0B1120;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  position: relative;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(to right, #3b82f6, #22d3ee);
  border-radius: 20rpx;
  position: relative;
  transition: width 400ms cubic-bezier(0.4, 0, 0.2, 1);
}

.progress-glow {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 32rpx;
  background: linear-gradient(to left, rgba(255, 255, 255, 0.3), transparent);
  filter: blur(4rpx);
}

.progress-percent {
  font-size: 22rpx;
  font-weight: 700;
  color: #60a5fa;
  text-align: right;
  margin-bottom: 24rpx;
}

/* 用量状态 */
.usage-status {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  border-radius: 24rpx;
}

.usage-status.good {
  background: rgba(16, 185, 129, 0.1);
  border: 1rpx solid rgba(16, 185, 129, 0.2);
}

.usage-status.warning {
  background: rgba(245, 158, 11, 0.1);
  border: 1rpx solid rgba(245, 158, 11, 0.2);
}

.usage-status.urgent {
  background: rgba(239, 68, 68, 0.1);
  border: 1rpx solid rgba(239, 68, 68, 0.2);
}

.status-icon-wrapper {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(16, 185, 129, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.status-check {
  font-size: 28rpx;
  color: #34d399;
  font-weight: 700;
  line-height: 1;
}

.status-text {
  font-size: 26rpx;
  color: #6ee7b7;
  font-weight: 500;
}

/* ==========================================================================
   订阅详情卡片
   ========================================================================== */

.detail-card {
  background: #121A2F;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  border-radius: 32rpx;
  overflow: hidden;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
}

.detail-label {
  font-size: 30rpx;
  color: #94a3b8;
  font-weight: 500;
}

.detail-value {
  font-size: 30rpx;
  color: #ffffff;
  font-weight: 600;
}

.detail-divider {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.05);
  margin: 0 32rpx;
}

/* 开关切换 */
.toggle-switch {
  width: 88rpx;
  height: 52rpx;
  background: #334155;
  border-radius: 26rpx;
  position: relative;
  transition: background 200ms ease;
}

.toggle-switch.active {
  background: #3b82f6;
}

.toggle-dot {
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  width: 40rpx;
  height: 40rpx;
  background: #ffffff;
  border-radius: 50%;
  transition: transform 300ms cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.toggle-switch.active .toggle-dot {
  transform: translateX(36rpx);
}

/* ==========================================================================
   底部操作按钮
   ========================================================================== */

.bottom-actions {
  display: flex;
  gap: 20rpx;
  padding: 0 40rpx 40rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 700;
  transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
}

.action-btn:active {
  transform: scale(0.98);
}

.action-btn.primary {
  background: linear-gradient(to right, #2563eb, #3b82f6);
  border: 1rpx solid rgba(59, 130, 246, 0.3);
  box-shadow: 0 0 32rpx rgba(37, 99, 235, 0.3);
  color: #ffffff;
}

.action-btn.primary:active {
  box-shadow: 0 0 40rpx rgba(37, 99, 235, 0.5);
}

.action-btn.danger {
  background: rgba(244, 63, 94, 0.1);
  border: 2rpx solid rgba(244, 63, 94, 0.3);
  color: #fb7185;
}

.action-btn.danger:active {
  background: rgba(244, 63, 94, 0.15);
  border-color: rgba(244, 63, 94, 0.4);
}

.btn-icon {
  font-size: 36rpx;
  font-weight: 300;
  line-height: 1;
}

.btn-text {
  line-height: 1;
}

/* ==========================================================================
   常见问题
   ========================================================================== */

.help-section {
  padding: 0 40rpx 40rpx;
  text-align: center;
}

.help-link {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  transition: opacity 0.2s ease;
}

.help-link:active {
  opacity: 0.7;
}

.help-icon {
  font-size: 32rpx;
  color: #64748b;
  font-weight: 300;
  line-height: 1;
}

.help-text {
  font-size: 26rpx;
  color: #64748b;
  font-weight: 500;
}

/* ==========================================================================
   底部占位
   ========================================================================== */

.bottom-spacer {
  height: calc(120rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}

/* ==========================================================================
   页面进入动画
   ========================================================================== */

.dark-page {
  animation: pageEnter 400ms cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes pageEnter {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
