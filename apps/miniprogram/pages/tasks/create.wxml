<view class="container">
  <view class="section card">
    <view class="section-title">平台选择</view>
    <view class="platform-grid">
      <view class="platform-item {{selectedPlatform === 'twitter' ? 'selected' : ''}}" bindtap="selectPlatform" data-platform="twitter">
        <view class="platform-icon">🐦</view>
        <view class="platform-name">Twitter</view>
        <view class="platform-status">✅ 已可用</view>
      </view>
      <view class="platform-item {{selectedPlatform === 'weibo' ? 'selected' : ''}}" bindtap="selectPlatform" data-platform="weibo">
        <view class="platform-icon">🔴</view>
        <view class="platform-name">微博</view>
        <view class="platform-status">⏳ 开发中</view>
      </view>
    </view>
  </view>

  <view class="section card">
    <view class="section-title">Twitter 账号</view>
    <input class="form-input" value="{{twitterHandle}}" bindinput="onHandleChange" placeholder="@elonmusk" />
    <view class="form-tip">输入要监控的 Twitter 用户名</view>
  </view>

  <view class="section card">
    <view class="section-title">通知设置</view>
    <view class="checkbox-item" bindtap="toggleEmail">
      <view class="checkbox {{notifyEmail ? 'checked' : ''}}"></view>
      <text class="checkbox-label">邮件通知</text>
    </view>
    <view class="checkbox-item" bindtap="toggleWebhook">
      <view class="checkbox {{notifyWebhook ? 'checked' : ''}}"></view>
      <text class="checkbox-label">Webhook 通知</text>
    </view>
  </view>

  <button class="submit-btn" bindtap="submitTask">创建监控任务</button>
</view>
