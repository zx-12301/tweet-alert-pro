/* ==========================================================================
   创建任务页 - Figma 设计 100% 还原
   深色主题
   ========================================================================== */

page {
  background: #0B1120;
  min-height: 100vh;
}

.dark-page {
  min-height: 100vh;
  background: #0B1120;
  position: relative;
  overflow: hidden;
  height: 100vh;
}

/* 背景装饰光晕 */
.bg-glow {
  position: absolute;
  top: 0;
  left: -20%;
  width: 140%;
  height: 40%;
  background: radial-gradient(ellipse at top, rgba(37, 99, 235, 0.15) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

/* ==========================================================================
   头部（固定）
   ========================================================================== */

.header-sticky {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: rgba(11, 17, 32, 0.8);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  padding-top: calc(88rpx + env(safe-area-inset-top));
  padding-bottom: 20rpx;
  padding-left: 40rpx;
  padding-right: 40rpx;
  z-index: 100;
}

.header-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.back-btn:active {
  background: rgba(255, 255, 255, 0.1);
  transform: scale(0.95);
}

.back-icon {
  font-size: 32rpx;
  color: #cbd5e1;
  font-weight: 300;
}

.header-info {
  flex: 1;
}

.header-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.3;
  margin-bottom: 4rpx;
}

.header-subtitle {
  display: block;
  font-size: 18rpx;
  color: #94a3b8;
}

/* 顶部占位 */
.top-spacer {
  height: calc(240rpx + env(safe-area-inset-top));
  flex-shrink: 0;
}

/* ==========================================================================
   表单区域
   ========================================================================== */

.main-scroll {
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  z-index: 10;
  overflow-x: hidden;
}

.form-section {
  padding: 0 40rpx 48rpx;
  box-sizing: border-box;
  width: 100%;
  overflow-x: hidden;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-title::before {
  content: '';
  width: 4rpx;
  height: 24rpx;
  background: #3b82f6;
  border-radius: 4rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-link {
  font-size: 22rpx;
  font-weight: 500;
  color: #60a5fa;
}

/* ==========================================================================
   平台选择
   ========================================================================== */

.platform-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.platform-card {
  position: relative;
  padding: 32rpx 24rpx;
  background: #121A2F;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  transition: all 0.3s ease;
  overflow: hidden;
}

.platform-card:active {
  transform: scale(0.96);
}

.platform-card.selected {
  background: rgba(59, 130, 246, 0.1);
  border-color: rgba(59, 130, 246, 0.5);
  box-shadow: 0 0 32rpx rgba(59, 130, 246, 0.15);
}

.platform-card.selected::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, transparent 100%);
  pointer-events: none;
}

.platform-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.icon-twitter {
  background: #E8F1FF;
}

.icon-weibo {
  background: #FFEAEA;
}

.platform-icon {
  font-size: 48rpx;
}

.platform-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
}

.platform-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  font-size: 18rpx;
  font-weight: 500;
  color: #94a3b8;
}

.platform-badge.active {
  background: rgba(16, 185, 129, 0.2);
  color: #10b981;
}

.platform-badge.warning {
  background: rgba(245, 158, 11, 0.1);
  color: #f59e0b;
  border: 1rpx solid rgba(245, 158, 11, 0.2);
}

.badge-icon {
  font-size: 20rpx;
  font-weight: 700;
}

/* ==========================================================================
   信息卡片
   ========================================================================== */

.info-card {
  background: #121A2F;
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  padding: 32rpx;
}

.form-item {
  margin-bottom: 8rpx;
}

.form-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.form-label text {
  font-size: 24rpx;
  font-weight: 600;
  color: #e2e8f0;
}

.required {
  color: #fb7185 !important;
}

.optional-badge {
  padding: 4rpx 12rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 8rpx;
  font-size: 18rpx;
  font-weight: 400;
  color: #94a3b8;
}

.input-wrapper {
  position: relative;
  width: 100%;
}

.form-input {
  width: 100%;
  padding: 24rpx 28rpx;
  background: #0B1120;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #ffffff;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: rgba(59, 130, 246, 0.5);
}

.input-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  padding-left: 8rpx;
  border-left: 2rpx solid rgba(100, 116, 139, 0.5);
}

.input-tip text {
  font-size: 18rpx;
  color: #64748b;
  line-height: 1.4;
}

.tip-icon {
  font-size: 20rpx;
}

.form-divider {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.05);
  margin: 40rpx 0;
}

.form-row {
  display: flex;
  gap: 24rpx;
}

.form-item.half {
  flex: 1;
}

/* ==========================================================================
   通知选项
   ========================================================================== */

.notify-options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.notify-option {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: #121A2F;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  border-radius: 32rpx;
  gap: 24rpx;
  transition: all 0.2s ease;
}

.notify-option:active {
  background: #162038;
}

.notify-option.selected {
  background: rgba(59, 130, 246, 0.1);
  border-color: rgba(59, 130, 246, 0.5);
}

.notify-checkbox {
  width: 40rpx;
  height: 40rpx;
  background: #0B1120;
  border: 2rpx solid #475569;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.notify-option.selected .notify-checkbox {
  background: #3b82f6;
  border-color: #3b82f6;
}

.checkmark {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 700;
}

.notify-content {
  flex: 1;
}

.notify-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #e2e8f0;
  margin-bottom: 4rpx;
}

.notify-desc {
  display: block;
  font-size: 18rpx;
  color: #94a3b8;
}

.notify-config {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  font-size: 16rpx;
  font-weight: 500;
  color: #94a3b8;
}

/* ==========================================================================
   提示框
   ========================================================================== */

.alert-box {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 28rpx;
  margin-top: 32rpx;
  background: rgba(245, 158, 11, 0.1);
  border: 1rpx solid rgba(245, 158, 11, 0.2);
  border-radius: 24rpx;
}

.alert-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.alert-text {
  font-size: 20rpx;
  color: rgba(251, 191, 36, 0.8);
  line-height: 1.5;
}

.alert-link {
  font-size: 20rpx;
  color: #60a5fa;
  font-weight: 600;
  text-decoration: underline;
}

/* ==========================================================================
   底部操作栏（固定）
   ========================================================================== */

.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(11, 17, 32, 0.9);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
  padding: 32rpx 40rpx calc(32rpx + env(safe-area-inset-bottom));
  z-index: 100;
}

.action-btns-row {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  padding: 28rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.98);
}

.action-btn-primary {
  flex: 2;
  background: linear-gradient(to right, #2563eb, #3b82f6);
  color: #ffffff;
  border: 1rpx solid rgba(59, 130, 246, 0.2);
  box-shadow: 0 0 32rpx rgba(37, 99, 235, 0.2);
}

.action-btn-primary:active {
  box-shadow: 0 0 40rpx rgba(37, 99, 235, 0.5);
}

.action-btn-secondary {
  background: rgba(255, 255, 255, 0.05);
  color: #94a3b8;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.action-btn-secondary:active {
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
}

/* ==========================================================================
   推荐账号弹窗
   ========================================================================== */

.recommendations-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.8);
  backdrop-filter: blur(8rpx);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  animation: fadeIn 0.2s ease;
}

.recommendations-card {
  width: 100%;
  max-width: 430px;
  background: #121A2F;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.recommendations-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.recommendations-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.recommendations-close {
  font-size: 40rpx;
  color: #94a3b8;
  padding: 16rpx;
}

.recommendations-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.recommendation-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: #0B1120;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.recommendation-item:active {
  background: #162038;
  border-color: rgba(59, 130, 246, 0.3);
}

.rec-avatar {
  width: 80rpx;
  height: 80rpx;
  background: rgba(59, 130, 246, 0.1);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.rec-info {
  flex: 1;
  min-width: 0;
}

.rec-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 4rpx;
}

.rec-handle {
  display: block;
  font-size: 22rpx;
  color: #60a5fa;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.rec-desc {
  display: block;
  font-size: 20rpx;
  color: #64748b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ==========================================================================
   高级选项动画
   ========================================================================== */

.advanced-options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 20rpx;
  animation: expandDown 0.3s ease;
}

@keyframes expandDown {
  from {
    opacity: 0;
    transform: translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 底部占位 */
.bottom-spacer-large {
  height: calc(280rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}
