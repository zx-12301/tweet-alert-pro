.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f9ff 0%, #f8fafc 100%);
  padding-bottom: 40rpx;
}

/* 页面头部 */
.page-header {
  margin: 0;
  border-radius: 0 0 48rpx 48rpx;
  padding: 60rpx 32rpx 48rpx;
  position: relative;
  overflow: hidden;
}

.page-header::before {
  content: '';
  position: absolute;
  top: -30%;
  right: -10%;
  width: 150%;
  height: 150%;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  pointer-events: none;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
  letter-spacing: -1rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.5;
}

/* 区块 */
.section {
  padding: 32rpx 24rpx;
}

.section-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-action {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 500;
}

/* 平台选择 */
.platform-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.platform-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 24rpx;
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  border: 2rpx solid transparent;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.platform-card:active {
  transform: scale(0.96);
}

.platform-card.selected {
  border-color: var(--primary-color);
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
}

.platform-icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  font-size: 56rpx;
}

.platform-icon-twitter {
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
}

.platform-icon-weibo {
  background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
}

.platform-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.platform-badge {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.platform-badge.available {
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
  color: #065f46;
}

.platform-badge.coming {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  color: #92400e;
}

/* 配置提示 */
.card-notice {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
  border-radius: var(--radius-md);
  border: 1rpx solid rgba(251, 146, 60, 0.2);
  margin-top: 20rpx;
}

.notice-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.notice-text {
  font-size: 24rpx;
  color: #9a3412;
  line-height: 1.5;
}

.notice-link {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 600;
  text-decoration: underline;
}

/* 推荐账号 */
.recommendation-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.recommendation-card {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: var(--card-bg);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-color);
  transition: all 0.2s ease;
}

.recommendation-card:active {
  transform: scale(0.96);
  box-shadow: var(--shadow-md);
}

.recommendation-avatar {
  font-size: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.recommendation-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  overflow: hidden;
}

.recommendation-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.recommendation-handle {
  font-size: 22rpx;
  color: var(--primary-color);
  font-weight: 500;
}

.recommendation-desc {
  font-size: 20rpx;
  color: var(--text-muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 表单卡片 */
.form-card {
  padding: 0;
  overflow: hidden;
}

.form-item {
  padding: 28rpx 32rpx;
}

.form-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.form-label text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.required {
  color: var(--danger-color);
}

.optional {
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 400;
}

.input-wrapper {
  position: relative;
}

.form-input {
  width: 100%;
  padding: 24rpx 28rpx;
  background: #f8fafc;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--text-primary);
  border: 1rpx solid var(--border-color);
  transition: all 0.2s ease;
}

.form-input:focus {
  background: #ffffff;
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(37, 99, 235, 0.1);
}

.input-placeholder {
  color: var(--text-muted);
}

.form-tip {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
  line-height: 1.4;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.form-item.half {
  flex: 1;
}

/* 通知卡片 */
.notification-cards {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.notification-card {
  padding: 0;
  overflow: hidden;
  transition: all 0.2s ease;
}

.notification-card:active {
  background: linear-gradient(90deg, #eff6ff 0%, #ffffff 100%);
}

.notification-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
}

.notification-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.checkbox.checked {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-color: var(--primary-color);
}

.checkmark {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.notification-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.notification-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.notification-desc {
  font-size: 22rpx;
  color: var(--text-muted);
}

.notification-require {
  font-size: 22rpx;
  color: var(--text-muted);
  flex-shrink: 0;
}

.notification-content {
  padding: 0 32rpx 28rpx;
}

/* 操作区域 */
.action-section {
  padding: 0 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-btn {
  width: 100%;
  padding: 32rpx;
  border-radius: var(--radius-md);
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s ease;
}

.action-btn[disabled] {
  opacity: 0.6;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--border-color), transparent);
  margin: 0 32rpx;
}

/* 安全区域 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
