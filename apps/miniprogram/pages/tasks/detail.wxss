.container {
  padding: 20rpx;
  background-color: #f3f4f6;
  min-height: 100vh;
}

/* 任务头部 */
.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #ffffff;
  margin-bottom: 20rpx;
}

.task-title {
  font-size: 40rpx;
  font-weight: 700;
}

.task-status {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  background-color: rgba(255, 255, 255, 0.2);
}

.task-status.active {
  background-color: rgba(16, 185, 129, 0.3);
}

.task-status.inactive {
  background-color: rgba(107, 114, 128, 0.3);
}

/* 任务信息 */
.task-info {
  margin-bottom: 20rpx;
}

.info-section {
  margin-bottom: 30rpx;
}

.info-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #6b7280;
}

.info-value {
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 500;
}

.keyword-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.keyword-tag {
  background-color: #eff6ff;
  color: #2563eb;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.channel-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.channel-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.channel-icon {
  font-size: 32rpx;
}

.channel-name {
  font-size: 26rpx;
  color: #1f2937;
}

/* 统计数据 */
.task-stats {
  margin-bottom: 20rpx;
}

.stats-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.stat-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  background-color: #f9fafb;
  border-radius: 12rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #2563eb;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #6b7280;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 40rpx;
}

.action-btn {
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: #ffffff;
}

.action-btn.secondary {
  background-color: #f9fafb;
  color: #374151;
  border: 1rpx solid #e5e7eb;
}

.action-btn.danger {
  background-color: #fee2e2;
  color: #dc2626;
}
