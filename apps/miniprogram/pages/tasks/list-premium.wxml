<view class="page-container animate-fade-in">
  <!-- 极简头部 -->
  <view class="header-section">
    <view class="header-content">
      <text class="premium-h1">监控任务</text>
      <text class="premium-caption header-subtitle">{{tasks.length}} 个任务</text>
    </view>
    
    <!-- 统计行 -->
    <view class="stats-row">
      <view class="stat-card-minimal">
        <text class="stat-value">{{stats.totalNotifications || 0}}</text>
        <text class="stat-label">总通知</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-card-minimal">
        <text class="stat-value">{{activeCount}}</text>
        <text class="stat-label">运行中</text>
      </view>
    </view>
  </view>

  <!-- 筛选器 - 极简胶囊 -->
  <view class="section">
    <view class="filter-row-minimal">
      <view class="filter-pill-minimal {{filterType === 'all' ? 'active' : ''}}" bindtap="setFilter" data-type="all">
        <text>全部</text>
      </view>
      <view class="filter-pill-minimal {{filterType === 'active' ? 'active' : ''}}" bindtap="setFilter" data-type="active">
        <text>运行中</text>
        <text class="filter-count">{{activeCount}}</text>
      </view>
      <view class="filter-pill-minimal {{filterType === 'paused' ? 'active' : ''}}" bindtap="setFilter" data-type="paused">
        <text>已暂停</text>
        <text class="filter-count">{{pausedCount}}</text>
      </view>
    </view>
  </view>

  <!-- 任务列表 -->
  <view wx:if="{{filteredTasks.length > 0}}" class="section">
    <view class="task-list-minimal">
      <view wx:for="{{filteredTasks}}" wx:key="id" class="task-card-minimal" bindtap="viewTaskDetail" data-id="{{item.id}}">
        <!-- 顶部信息 -->
        <view class="task-header-minimal">
          <view class="task-left-minimal">
            <view class="task-avatar-minimal">
              <text>@</text>
            </view>
            <view class="task-info-minimal">
              <text class="task-handle-minimal">@{{item.twitterHandle}}</text>
              <text class="task-meta-minimal">ID: {{item.id.slice(-6)}}</text>
            </view>
          </view>
          <view class="task-status-minimal {{item.isActive ? 'active' : 'inactive'}}">
            <view class="status-dot-minimal"></view>
            <text class="status-text-minimal">{{item.isActive ? '运行中' : '已暂停'}}</text>
          </view>
        </view>

        <!-- 关键词 -->
        <view wx:if="{{item.keywords}}" class="task-keywords-minimal">
          <view wx:for="{{JSON.parse(item.keywords)}}" wx:key="*this" wx:for-item="keyword" class="keyword-tag-minimal">
            <text>{{keyword}}</text>
          </view>
        </view>

        <!-- 底部数据 -->
        <view class="task-footer-minimal">
          <view class="footer-stat-minimal">
            <text class="footer-stat-icon">📬</text>
            <text class="footer-stat-value">{{item.totalNotifications || 0}}</text>
          </view>
          <view class="footer-divider-minimal"></view>
          <view class="footer-stat-minimal">
            <text class="footer-stat-icon">🕐</text>
            <text class="footer-stat-value">{{item.lastCheckedAt ? '刚刚' : '-'}}</text>
          </view>
          <view class="footer-divider-minimal"></view>
          <view class="footer-action-minimal">
            <button class="icon-btn-minimal" bindtap="toggleTask" data-id="{{item.id}}" data-stop-propagation="true">
              <text>{{item.isActive ? '暂停' : '启动'}}</text>
            </button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty-section-minimal">
    <view class="empty-illustration-minimal">
      <text class="empty-icon-premium">📋</text>
    </view>
    <text class="empty-title-premium">暂无监控任务</text>
    <text class="empty-desc-premium">创建第一个任务，开始追踪您关注的用户</text>
    <button class="premium-btn premium-btn-primary" bindtap="createTask">
      + 创建任务
    </button>
  </view>
  
  <!-- 底部安全区域 -->
  <view class="tabbar-safe-area"></view>
</view>
