/* ==========================================================================
   任务列表页 - Premium Design
   极简主义卡片设计
   ========================================================================== */

.page-container {
  min-height: 100vh;
  background-color: var(--bg);
}

/* ==========================================================================
   筛选器 - 极简胶囊
   ========================================================================== */

.filter-row-minimal {
  display: flex;
  gap: var(--space-sm);
  padding: 0 0 var(--space-lg);
}

.filter-pill-minimal {
  display: inline-flex;
  align-items: center;
  gap: var(--space-xs);
  padding: 12rpx 24rpx;
  background: var(--surface);
  border-radius: var(--radius-full);
  border: 1rpx solid var(--border);
  transition: all 0.3s var(--ease-standard);
}

.filter-pill-minimal text {
  font-size: var(--tiny-size);
  color: var(--text-secondary);
  font-weight: 400;
}

.filter-pill-minimal.active {
  background: var(--primary);
  border-color: var(--primary);
}

.filter-pill-minimal.active text {
  color: #ffffff;
}

.filter-count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-full);
  font-size: 20rpx;
  font-weight: 600;
}

.filter-pill-minimal.active .filter-count {
  background: rgba(255, 255, 255, 0.25);
}

/* ==========================================================================
   任务列表 - 极简卡片
   ========================================================================== */

.task-list-minimal {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.task-card-minimal {
  background: var(--surface);
  border-radius: var(--radius-xl);
  padding: var(--space-lg);
  box-shadow: var(--shadow-xs);
  transition: all 0.2s var(--ease-standard);
  border: none;
}

.task-card-minimal:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-xs);
  background: var(--bg-secondary);
}

/* 任务头部 */
.task-header-minimal {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--space-md);
}

.task-left-minimal {
  display: flex;
  gap: var(--space-md);
  flex: 1;
}

.task-avatar-minimal {
  flex-shrink: 0;
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-full);
  background: var(--bg-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.task-info-minimal {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  justify-content: center;
}

.task-handle-minimal {
  font-size: var(--body-size);
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.5rpx;
}

.task-meta-minimal {
  font-size: var(--tiny-size);
  color: var(--text-tertiary);
  font-family: monospace;
}

/* 任务状态 */
.task-status-minimal {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  padding: 8rpx 16rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

.task-status-minimal.active {
  background: var(--success-bg);
}

.task-status-minimal.inactive {
  background: var(--bg-secondary);
}

.status-dot-minimal {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--text-tertiary);
}

.task-status-minimal.active .status-dot-minimal {
  background: var(--success);
  box-shadow: 0 0 0 4rpx var(--success-bg);
}

.status-text-minimal {
  font-size: var(--tiny-size);
  font-weight: 500;
  color: var(--text-secondary);
}

.task-status-minimal.active .status-text-minimal {
  color: var(--success);
}

/* 关键词 */
.task-keywords-minimal {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-bottom: var(--space-md);
}

.keyword-tag-minimal {
  display: inline-flex;
  padding: 8rpx 16rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-full);
  font-size: var(--tiny-size);
  color: var(--text-secondary);
  font-weight: 400;
}

/* 任务底部 */
.task-footer-minimal {
  display: flex;
  align-items: center;
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--border-light);
}

.footer-stat-minimal {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.footer-stat-icon {
  font-size: 28rpx;
}

.footer-stat-value {
  font-size: var(--tiny-size);
  font-weight: 500;
  color: var(--text-secondary);
}

.footer-divider-minimal {
  width: 1rpx;
  height: 24rpx;
  background: var(--border);
  margin: 0 var(--space-md);
}

.footer-action-minimal {
  margin-left: auto;
}

.icon-btn-minimal {
  padding: 8rpx 20rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-full);
  font-size: var(--tiny-size);
  font-weight: 500;
  color: var(--text-primary);
  border: none;
  transition: all 0.2s var(--ease-standard);
}

.icon-btn-minimal:active {
  background: var(--border);
  transform: scale(0.95);
}

/* ==========================================================================
   空状态 - 极简设计
   ========================================================================== */

.empty-section-minimal {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-3xl) var(--space-lg);
  text-align: center;
}

.empty-illustration-minimal {
  margin-bottom: var(--space-xl);
}

.empty-icon-premium {
  font-size: 100rpx;
  opacity: 0.3;
  display: block;
}

.empty-title-premium {
  font-size: var(--h2-size);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
  display: block;
}

.empty-desc-premium {
  font-size: var(--caption-size);
  color: var(--text-tertiary);
  line-height: 1.6;
  margin-bottom: var(--space-2xl);
  display: block;
}

/* ==========================================================================
   响应式优化
   ========================================================================== */

@media (min-width: 768px) {
  .task-card-minimal {
    padding: var(--space-xl);
  }
  
  .task-avatar-minimal {
    width: 96rpx;
    height: 96rpx;
  }
}
