<view class="container">
  <view class="page-header">
    <view class="page-title">监控任务</view>
    <view class="create-btn" bindtap="createTask">+ 创建任务</view>
  </view>

  <!-- 任务列表 -->
  <view wx:if="{{tasks.length > 0}}" class="task-list">
    <view wx:for="{{tasks}}" wx:key="id" class="task-card card" bindtap="viewTaskDetail" data-id="{{item.id}}">
      <view class="task-header">
        <view class="task-handle">@{{item.twitterHandle}}</view>
        <view class="task-status {{item.isActive ? 'active' : 'inactive'}}">
          {{item.isActive ? '运行中' : '已暂停'}}
        </view>
      </view>
      
      <view wx:if="{{item.keywords}}" class="task-keywords">
        <text class="keyword-tag" wx:for="{{JSON.parse(item.keywords)}}" wx:key="*this" wx:for-item="keyword">
          {{keyword}}
        </text>
      </view>
      
      <view class="task-stats">
        <view class="stat-item">
          <text class="stat-label">通知数</text>
          <text class="stat-value">{{item.totalNotifications || 0}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">最后检查</text>
          <text class="stat-value">{{item.lastCheckedAt ? '刚刚' : '从未'}}</text>
        </view>
      </view>
      
      <view class="task-actions">
        <button class="action-btn delete" bindtap="deleteTask" data-id="{{item.id}}" data-stop-propagation="true">删除</button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty-state">
    <view class="empty-icon">📋</view>
    <view class="empty-title">暂无监控任务</view>
    <view class="empty-desc">创建第一个 Twitter 监控任务吧！</view>
    <button class="create-btn-large" bindtap="createTask">创建任务</button>
  </view>
</view>
