<view class="dark-page">
  <!-- 背景装饰光晕 -->
  <view class="bg-glow"></view>

  <!-- 主滚动区域 -->
  <scroll-view class="main-scroll" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
    
    <!-- 顶部安全区域 -->
    <view class="top-safe-area"></view>

    <!-- 头部区域 -->
    <view class="header-section">
      <view class="header-row">
        <view class="title-wrapper">
          <text class="page-title">监控任务</text>
          <view class="task-count-badge">{{tasks.length}} 个任务</view>
        </view>
        <view class="refresh-btn" bindtap="refreshTasks">
          <text class="refresh-icon">🔄</text>
          <text class="refresh-text">刷新</text>
        </view>
      </view>
      <text class="page-subtitle">实时监控您的 Twitter 账号动态</text>
    </view>

    <!-- 4 格统计卡片 -->
    <view class="stats-grid">
      <view class="stat-card stat-blue">
        <view class="stat-card-header">
          <text class="stat-card-title">总任务数</text>
          <view class="stat-icon-box icon-blue">
            <text>▦</text>
          </view>
        </view>
        <text class="stat-card-value">{{stats.totalTasks}}</text>
      </view>
      
      <view class="stat-card stat-green">
        <view class="stat-card-header">
          <text class="stat-card-title">活跃任务</text>
          <view class="stat-icon-box icon-green">
            <text>⚡</text>
          </view>
        </view>
        <text class="stat-card-value">{{stats.activeTasks}}</text>
      </view>
      
      <view class="stat-card stat-purple">
        <view class="stat-card-header">
          <text class="stat-card-title">总通知数</text>
          <view class="stat-icon-box icon-purple">
            <text>🔔</text>
          </view>
        </view>
        <text class="stat-card-value">{{stats.totalNotifications}}</text>
      </view>
      
      <view class="stat-card stat-orange">
        <view class="stat-card-header">
          <text class="stat-card-title">今日通知</text>
          <view class="stat-icon-box icon-orange">
            <text>🕐</text>
          </view>
        </view>
        <text class="stat-card-value">{{stats.todayNotifications}}</text>
      </view>
    </view>

    <!-- 筛选标签 -->
    <view class="filter-tabs">
      <view class="filter-tab {{filterType === 'all' ? 'active' : ''}}" bindtap="setFilter" data-type="all">
        <text>全部</text>
        <view class="tab-count {{filterType === 'all' ? 'active' : ''}}">{{stats.totalTasks}}</view>
      </view>
      <view class="filter-tab {{filterType === 'running' ? 'active' : ''}}" bindtap="setFilter" data-type="running">
        <text>运行中</text>
        <view class="tab-count {{filterType === 'running' ? 'active' : ''}}">{{stats.activeTasks}}</view>
      </view>
      <view class="filter-tab {{filterType === 'paused' ? 'active' : ''}}" bindtap="setFilter" data-type="paused">
        <text>已暂停</text>
        <view class="tab-count {{filterType === 'paused' ? 'active' : ''}}">{{pausedCount}}</view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{tasks.length === 0}}" class="empty-state-section">
      <view class="empty-illustration">
        <view class="empty-icon-wrapper">
          <view class="icon-bg-glow"></view>
          <text class="empty-icon">📋</text>
          <view class="empty-decor-dot"></view>
        </view>
      </view>
      <text class="empty-title">暂无监控任务</text>
      <text class="empty-desc">您还没有创建任何任务。开始追踪您关注的用户动态吧！</text>
      <view class="create-btn-wrapper">
        <view class="create-btn" bindtap="createTask">
          <text class="create-btn-icon">+</text>
          <text class="create-btn-text">创建第一个任务</text>
        </view>
      </view>
    </view>

    <!-- 任务列表 -->
    <view wx:else class="task-list-section">
      <view wx:for="{{filteredTasks}}" wx:key="id" class="task-card" bindtap="viewTaskDetail" data-id="{{item.id}}">
        <view class="task-card-header">
          <view class="task-avatar">@{{item.twitterHandle}}</view>
          <view class="task-info">
            <text class="task-handle">@{{item.twitterHandle}}</text>
            <text class="task-meta">ID: {{item.id.slice(-6)}}</text>
          </view>
          <view class="task-status {{item.isActive ? 'active' : ''}}">
            <view class="status-dot"></view>
            <text class="status-text">{{item.isActive ? '运行中' : '已暂停'}}</text>
          </view>
        </view>
        
        <view class="task-card-footer">
          <view class="footer-stat">
            <text class="footer-stat-icon">👍</text>
            <text class="footer-stat-value">{{item.totalNotifications || 0}}</text>
          </view>
          <view class="footer-stat">
            <text class="footer-stat-icon">🕐</text>
            <text class="footer-stat-value">{{item.lastCheckedAt ? '刚刚' : '-'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-spacer"></view>
  </scroll-view>
</view>
