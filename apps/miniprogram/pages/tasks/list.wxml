<view class="premium-container page-enter">
  <!-- 极简头部 - 清晰信息层级 -->
  <view class="premium-header">
    <view class="header-content">
      <view class="header-title-row">
        <text class="page-title">监控任务</text>
        <text class="page-count">{{tasks.length}} 个任务</text>
      </view>
      <text class="page-subtitle">实时追踪 Twitter 动态</text>
    </view>

    <!-- 简洁统计卡片 -->
    <view class="stats-grid">
      <view class="stat-mini-card">
        <view class="stat-mini-icon">📬</view>
        <view class="stat-mini-content">
          <text class="stat-mini-value">{{totalNotifications || 0}}</text>
          <text class="stat-mini-label">总通知</text>
        </view>
      </view>
      <view class="stat-mini-card">
        <view class="stat-mini-icon">⚡</view>
        <view class="stat-mini-content">
          <text class="stat-mini-value">{{activeCount}}</text>
          <text class="stat-mini-label">运行中</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 极简筛选 - 无溢出滚动 -->
  <view class="section">
    <view class="filter-row">
      <view class="filter-pill {{filterType === 'all' ? 'active' : ''}}" bindtap="setFilter" data-type="all">
        <text class="filter-pill-text">全部</text>
      </view>
      <view class="filter-pill {{filterType === 'active' ? 'active' : ''}}" bindtap="setFilter" data-type="active">
        <text class="filter-pill-text">运行中</text>
        <view class="filter-pill-count">{{activeCount}}</view>
      </view>
      <view class="filter-pill {{filterType === 'paused' ? 'active' : ''}}" bindtap="setFilter" data-type="paused">
        <text class="filter-pill-text">已暂停</text>
        <view class="filter-pill-count">{{pausedCount}}</view>
      </view>
    </view>
  </view>

  <!-- 任务列表 - 精致卡片 -->
  <view wx:if="{{filteredTasks.length > 0}}" class="section">
    <view wx:for="{{filteredTasks}}" wx:key="id" class="task-mini-card" bindtap="viewTaskDetail" data-id="{{item.id}}">
      <!-- 顶部信息 -->
      <view class="task-mini-header">
        <view class="task-mini-left">
          <view class="task-mini-avatar">
            <text class="avatar-mini">@</text>
          </view>
          <view class="task-mini-info">
            <text class="task-mini-handle">@{{item.twitterHandle}}</text>
            <text class="task-mini-meta">ID: {{item.id.slice(-6)}}</text>
          </view>
        </view>
        <view class="task-mini-status {{item.isActive ? 'active' : 'inactive'}}">
          <text class="status-mini-dot">●</text>
          <text class="status-mini-text">{{item.isActive ? '运行中' : '已暂停'}}</text>
        </view>
      </view>

      <!-- 关键词 -->
      <view wx:if="{{item.keywords}}" class="task-mini-keywords">
        <view wx:for="{{JSON.parse(item.keywords)}}" wx:key="*this" wx:for-item="keyword" class="keyword-mini">
          <text class="keyword-mini-text">{{keyword}}</text>
        </view>
      </view>

      <!-- 底部数据 -->
      <view class="task-mini-footer">
        <view class="footer-stat">
          <text class="footer-stat-icon">📬</text>
          <text class="footer-stat-value">{{item.totalNotifications || 0}}</text>
        </view>
        <view class="footer-divider"></view>
        <view class="footer-stat">
          <text class="footer-stat-icon">🕐</text>
          <text class="footer-stat-value">{{item.lastCheckedAt ? '刚刚' : '-'}}</text>
        </view>
        <view class="footer-divider"></view>
        <view class="footer-actions">
          <button class="icon-btn-mini btn-toggle" bindtap="toggleTask" data-id="{{item.id}}" data-stop-propagation="true">
            <text class="icon-btn-mini-text">{{item.isActive ? '暂停' : '启动'}}</text>
          </button>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 - 极简设计 -->
  <view wx:else class="empty-section">
    <view class="empty-illustration">
      <text class="empty-icon-premium">📋</text>
    </view>
    <text class="empty-title-premium">暂无监控任务</text>
    <text class="empty-desc-premium">创建第一个任务，开始追踪您关注的用户动态</text>
    <button class="btn-primary-premium" bindtap="createTask">
      + 创建任务
    </button>
  </view>
</view>
</view>
