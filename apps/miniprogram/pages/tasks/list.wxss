/* ==========================================================================
   任务列表页 - Figma 设计 100% 还原
   深色主题
   ========================================================================== */

page {
  background: #0B1120;
  min-height: 100vh;
}

.dark-page {
  min-height: 100vh;
  background: #0B1120;
  position: relative;
  overflow: hidden;
  height: 100vh;
}

/* 背景装饰光晕 */
.bg-glow {
  position: absolute;
  top: -10%;
  left: -10%;
  width: 120%;
  height: 50%;
  background: radial-gradient(ellipse at top, rgba(30, 58, 138, 0.2) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

/* 主滚动区域 */
.main-scroll {
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  z-index: 10;
}

/* 顶部安全区域（增加间距） */
.top-safe-area {
  height: calc(88rpx + env(safe-area-inset-top));
  flex-shrink: 0;
}

/* ==========================================================================
   头部区域
   ========================================================================== */

.header-section {
  padding: 56rpx 40rpx 48rpx;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 8rpx;
}

.title-wrapper {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.5rpx;
}

.task-count-badge {
  padding: 8rpx 16rpx;
  background: #121A2F;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  font-size: 20rpx;
  color: #94a3b8;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.refresh-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: rgba(59, 130, 246, 0.1);
  border: 1rpx solid rgba(59, 130, 246, 0.2);
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.refresh-btn:active {
  transform: scale(0.95);
  background: rgba(59, 130, 246, 0.15);
}

.refresh-icon {
  font-size: 28rpx;
}

.refresh-text {
  font-size: 20rpx;
  font-weight: 500;
  color: #60a5fa;
}

.page-subtitle {
  display: block;
  font-size: 20rpx;
  color: #64748b;
}

/* ==========================================================================
   统计卡片网格
   ========================================================================== */

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 0 40rpx 64rpx;
}

.stat-card {
  background: #121A2F;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  position: relative;
  overflow: hidden;
  transition: all 0.2s ease;
}

.stat-card:active {
  background: #162038;
}

.stat-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.stat-card-title {
  font-size: 20rpx;
  font-weight: 500;
  color: #94a3b8;
}

.stat-icon-box {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.icon-blue {
  background: rgba(59, 130, 246, 0.1);
  border-color: rgba(59, 130, 246, 0.2);
}

.icon-green {
  background: rgba(16, 185, 129, 0.1);
  border-color: rgba(16, 185, 129, 0.2);
}

.icon-purple {
  background: rgba(139, 92, 246, 0.1);
  border-color: rgba(139, 92, 246, 0.2);
}

.icon-orange {
  background: rgba(245, 158, 11, 0.1);
  border-color: rgba(245, 158, 11, 0.2);
}

.stat-card-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -1rpx;
}

/* 背景光晕装饰 */
.stat-card::after {
  content: '';
  position: absolute;
  bottom: -48rpx;
  right: -48rpx;
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  filter: blur(64rpx);
  opacity: 0.2;
  transition: opacity 0.3s ease;
}

.stat-blue::after {
  background: rgba(59, 130, 246, 0.4);
}

.stat-green::after {
  background: rgba(16, 185, 129, 0.4);
}

.stat-purple::after {
  background: rgba(139, 92, 246, 0.4);
}

.stat-orange::after {
  background: rgba(245, 158, 11, 0.4);
}

.stat-card:active::after {
  opacity: 0.4;
}

/* ==========================================================================
   筛选标签
   ========================================================================== */

.filter-tabs {
  display: flex;
  gap: 16rpx;
  padding: 0 40rpx 48rpx;
  overflow-x: auto;
}

.filter-tab {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 32rpx;
  background: #121A2F;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #94a3b8;
  transition: all 0.2s ease;
  white-space: nowrap;
}

.filter-tab:active {
  transform: scale(0.95);
  background: #1A243D;
}

.filter-tab.active {
  background: #3b82f6;
  border-color: rgba(59, 130, 246, 0.5);
  color: #ffffff;
  box-shadow: 0 0 24rpx rgba(37, 99, 235, 0.3);
}

.tab-count {
  padding: 4rpx 12rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  font-size: 18rpx;
  font-weight: 700;
  color: #64748b;
}

.filter-tab.active .tab-count {
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
}

/* ==========================================================================
   空状态
   ========================================================================== */

.empty-state-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx 120rpx;
  flex: 1;
}

.empty-illustration {
  margin-bottom: 48rpx;
}

.empty-icon-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.icon-bg-glow {
  position: absolute;
  inset: 0;
  background: rgba(59, 130, 246, 0.2);
  border-radius: 50%;
  filter: blur(48rpx);
  animation: glowPulse 3s ease-in-out infinite;
}

@keyframes glowPulse {
  0%, 100% { opacity: 0.2; }
  50% { opacity: 0.3; }
}

.empty-icon {
  position: absolute;
  inset: 0;
  width: 160rpx;
  height: 160rpx;
  background: #121A2F;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  box-shadow: 0 8rpx 30px rgba(0, 0, 0, 0.2);
  transform: rotate(3deg);
}

.empty-decor-dot {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 48rpx;
  height: 48rpx;
  background: #1A243D;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.empty-decor-dot::after {
  content: '';
  width: 12rpx;
  height: 12rpx;
  background: #3b82f6;
  border-radius: 50%;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 20rpx;
  color: #64748b;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 64rpx;
  max-width: 440rpx;
}

.create-btn-wrapper {
  width: 100%;
  max-width: 560rpx;
}

.create-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 28rpx 64rpx;
  background: linear-gradient(to right, #2563eb, #3b82f6);
  border-radius: 32rpx;
  border: 1rpx solid rgba(59, 130, 246, 0.2);
  box-shadow: 0 0 32rpx rgba(59, 130, 246, 0.3);
  transition: all 0.2s ease;
}

.create-btn:active {
  transform: scale(0.95);
  box-shadow: 0 0 40rpx rgba(59, 130, 246, 0.5);
}

.create-btn-icon {
  font-size: 40rpx;
  font-weight: 300;
  color: #ffffff;
}

.create-btn-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #ffffff;
}

/* ==========================================================================
   任务列表
   ========================================================================== */

.task-list-section {
  padding: 0 40rpx 40rpx;
}

.task-card {
  background: #121A2F;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
  transition: all 0.2s ease;
}

.task-card:active {
  border-color: rgba(59, 130, 246, 0.3);
}

.task-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.task-left {
  display: flex;
  gap: 20rpx;
}

.task-avatar {
  width: 80rpx;
  height: 80rpx;
  background: rgba(59, 130, 246, 0.1);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #60a5fa;
  border: 1rpx solid rgba(59, 130, 246, 0.2);
}

.task-info {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.task-handle {
  font-size: 28rpx;
  font-weight: 600;
  color: #60a5fa;
  margin-bottom: 8rpx;
}

.task-meta {
  font-size: 20rpx;
  color: #64748b;
  font-family: monospace;
}

.task-status {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
}

.task-status.active {
  background: rgba(16, 185, 129, 0.1);
}

.task-status.inactive {
  background: rgba(255, 255, 255, 0.05);
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #94a3b8;
}

.task-status.active .status-dot {
  background: #10b981;
  box-shadow: 0 0 12rpx rgba(16, 185, 129, 0.5);
}

.status-text {
  font-size: 20rpx;
  font-weight: 500;
  color: #94a3b8;
}

.task-status.active .status-text {
  color: #10b981;
}

.task-keywords {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.keyword-tag {
  background: rgba(59, 130, 246, 0.1);
  color: #60a5fa;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 500;
  border: 1rpx solid rgba(59, 130, 246, 0.2);
}

.task-card-footer {
  display: flex;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.footer-stat {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.footer-stat-icon {
  font-size: 28rpx;
}

.footer-stat-value {
  font-size: 22rpx;
  font-weight: 500;
  color: #94a3b8;
}

.footer-divider {
  width: 1rpx;
  height: 32rpx;
  background: rgba(255, 255, 255, 0.05);
  margin: 0 32rpx;
}

/* 底部占位 */
.bottom-spacer {
  height: calc(98rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}
